<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroCompraController">

    <VBox spacing="16" style="-fx-padding: 22 28 10 28; -fx-background-color: #EEF4FB;">

        <!-- TÍTULO -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 24px;" text="📦" />
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Registro de Compras" />
                <Rectangle fill="#D6E8F5" height="24" width="1" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Complete los datos de la compra" />
            </HBox>
            <Separator />
            <Label style="-fx-font-size: 11px; -fx-text-fill: #E53935;" text="* Campos obligatorios" />
        </VBox>

        <!-- PANEL DE CONSULTA (OCULTO INICIALMENTE) -->
        <VBox fx:id="consultaPanel" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 15 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" managed="false" visible="false">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍 Buscar Compras" />
            <HBox spacing="10">
                <TextField fx:id="txtBuscar" prefHeight="36" HBox.hgrow="ALWAYS" promptText="Buscar por ID, proveedor o número de factura..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                <Button fx:id="btnBuscar" onAction="#buscarCompra" prefHeight="36" prefWidth="90" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Buscar" />
                <Button fx:id="btnVerTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" style="-fx-background-color: #EEF4FB; -fx-text-fill: #1A6BAD; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Ver todos" />
                <Button fx:id="btnCerrarConsulta" onAction="#cerrarConsulta" prefHeight="36" prefWidth="95" style="-fx-background-color: #E53935; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="✖ Cerrar" />
            </HBox>

            <!-- TABLA DE COMPRAS -->
            <TableView fx:id="tblCompras" prefHeight="250" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colProveedor" prefWidth="200" text="Proveedor" />
                    <TableColumn fx:id="colFecha" prefWidth="120" text="Fecha" />
                    <TableColumn fx:id="colNroFactura" prefWidth="150" text="Nro. Factura" />
                    <TableColumn fx:id="colTotal" prefWidth="120" text="Total" />
                    <TableColumn fx:id="colEstado" prefWidth="100" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay compras registradas" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- FORMULARIO DE REGISTRO/EDICIÓN -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="📋 Datos de la Compra" />

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                </columnConstraints>

                <!-- Fila 0: Proveedor | Empleado | Comprobante -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🏢 Proveedor *" />
                    <ComboBox fx:id="cmbProveedor" prefHeight="34" promptText="Seleccione proveedor" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="👔 Empleado *" />
                    <ComboBox fx:id="cmbEmpleado" prefHeight="34" promptText="Seleccione empleado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📄 Comprobante" />
                    <ComboBox fx:id="cmbComprobante" prefHeight="34" promptText="Seleccione comprobante" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>

                <!-- Fila 1: Fecha | Nro Factura | Estado -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📅 Fecha *" />
                    <DatePicker fx:id="dateFecha" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🧾 Número de factura" />
                    <TextField fx:id="txtNroFacturaProv" promptText="Ej: FAC-00123" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📌 Estado *" />
                    <ComboBox fx:id="cmbEstado" prefHeight="34" promptText="Seleccione estado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
            </GridPane>

            <Separator />

            <!-- SECCIÓN DE PRODUCTOS -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size: 14px;" text="🛒" />
                    <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Productos de la Compra" />
                </HBox>

                <GridPane hgap="10" vgap="8">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="40" />
                        <ColumnConstraints percentWidth="15" />
                        <ColumnConstraints percentWidth="15" />
                        <ColumnConstraints percentWidth="15" />
                        <ColumnConstraints percentWidth="15" />
                    </columnConstraints>

                    <VBox GridPane.columnIndex="0">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Producto *" />
                        <ComboBox fx:id="cmbProductoDetalle" prefHeight="34" promptText="Seleccione producto" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                    </VBox>
                    <VBox GridPane.columnIndex="1">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Cantidad *" />
                        <TextField fx:id="txtCantidad" promptText="1" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                    </VBox>
                    <VBox GridPane.columnIndex="2">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Precio Unit. *" />
                        <TextField fx:id="txtPrecioUnitario" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                    </VBox>
                    <VBox GridPane.columnIndex="3">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Descuento" />
                        <TextField fx:id="txtDescuentoProducto" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                    </VBox>
                    <VBox alignment="BOTTOM_CENTER" GridPane.columnIndex="4">
                        <Button fx:id="btnAgregarProducto" onAction="#agregarProducto" prefHeight="34" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="➕ Agregar" />
                    </VBox>
                </GridPane>

                <!-- Tabla de detalle de productos -->
                <TableView fx:id="tblDetalleProductos" prefHeight="180" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colProdNombre" prefWidth="250" text="Producto" />
                        <TableColumn fx:id="colProdCantidad" prefWidth="80" text="Cantidad" />
                        <TableColumn fx:id="colProdPrecio" prefWidth="120" text="Precio Unit." />
                        <TableColumn fx:id="colProdDescuento" prefWidth="120" text="Descuento" />
                        <TableColumn fx:id="colProdSubtotal" prefWidth="120" text="Subtotal" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay productos agregados" />
                    </placeholder>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btnEliminarProducto" onAction="#eliminarProductoSeleccionado" prefHeight="30" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;" text="🗑️ Eliminar Seleccionado" />
                </HBox>
            </VBox>

            <Separator />

            <!-- Totales -->
            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                    <ColumnConstraints percentWidth="25" />
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💰 Subtotal (RD$)" />
                    <TextField fx:id="txtSubtotal" editable="false" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-background-color: #F8FAFC;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🏷️ Descuento Total" />
                    <TextField fx:id="txtDescuento" editable="false" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-background-color: #F8FAFC;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📊 ITBIS (18%)" />
                    <TextField fx:id="txtItbis" editable="false" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-background-color: #F8FAFC;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💵 Total (RD$)" />
                    <TextField fx:id="txtTotal" editable="false" prefHeight="40" promptText="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-text-fill: #1A6BAD; -fx-background-color: #F8FAFC;" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- BARRA DE ACCIONES -->
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 28 14 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, -2, 0);">
            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="* Campos obligatorios" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnConsultar" onAction="#abrirConsulta" prefHeight="40" prefWidth="130" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand;" text="🔍 Consultar" />
            <Button fx:id="btnLimpiar" onAction="#limpiarCampos" prefHeight="40" prefWidth="120" style="-fx-background-color: white; -fx-text-fill: #546E7A; -fx-font-weight: bold; -fx-font-size: 13px; -fx-border-color: #B0BEC5; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" text="🧹 Limpiar" />
            <Button fx:id="btnEliminar" onAction="#eliminarCompra" prefHeight="40" prefWidth="130" style="-fx-background-color: white; -fx-text-fill: #E53935; -fx-font-weight: bold; -fx-font-size: 13px; -fx-border-color: #EF5350; -fx-border-radius: 10; -fx-background-radius: 10; -fx-cursor: hand;" text="🗑 Eliminar" />
            <Button fx:id="btnEditar" onAction="#editarCompra" prefHeight="40" prefWidth="130" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(46,125,50,0.35), 8, 0, 0, 3);" text="✏ Editar" />
            <Button fx:id="btnGuardar" onAction="#guardarCompra" prefHeight="40" prefWidth="170" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(26,107,173,0.35), 8, 0, 0, 3);" text="✔ Guardar Compra" />
        </HBox>
    </VBox>
</ScrollPane>