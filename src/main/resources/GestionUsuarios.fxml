<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" stylesheets="@estilos.css" style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.GestionUsuarioController">

    <VBox spacing="16" style="-fx-padding: 22 28 10 28; -fx-background-color: #EEF4FB;">

        <!-- TÍTULO -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 24px;" text="👥" />
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Gestión de Usuarios" />
                <Rectangle fill="#D6E8F5" height="24" width="1" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Complete los datos del usuario" />
            </HBox>
            <Separator />
            <Label style="-fx-font-size: 11px; -fx-text-fill: #E53935;" text="* Campos obligatorios" />
        </VBox>

        <!-- PANEL DE CONSULTA (OCULTO INICIALMENTE) -->
        <VBox fx:id="consultaPanel" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 15 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" managed="false" visible="false">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍 Buscar Usuarios" />
            <HBox spacing="10">
                <TextField fx:id="txtBuscar" prefHeight="36" HBox.hgrow="ALWAYS" promptText="Buscar por usuario, nombre completo, email o cargo..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                <Button fx:id="btnBuscar" onAction="#buscarUsuario" prefHeight="36" prefWidth="90" styleClass="btn-search" text="Buscar" />
                <Button fx:id="btnVerTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" styleClass="btn-outline" text="Ver todos" />
                <Button fx:id="btnCerrarConsulta" onAction="#cerrarConsulta" prefHeight="36" prefWidth="95" styleClass="btn-cerrar" text="Cerrar" />
            </HBox>

            <!-- TABLA DE USUARIOS -->
            <TableView fx:id="tblUsuarios" prefHeight="300" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colIdUsuario" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colNombreUsuario" prefWidth="120" text="Usuario" />
                    <TableColumn fx:id="colNombreCompleto" prefWidth="180" text="Nombre Completo" />
                    <TableColumn fx:id="colEmail" prefWidth="180" text="Email" />
                    <TableColumn fx:id="colCargo" prefWidth="120" text="Cargo" />
                    <TableColumn fx:id="colTelefono" prefWidth="100" text="Teléfono" />
                    <TableColumn fx:id="colFechaRegistro" prefWidth="120" text="Fecha Registro" />
                    <TableColumn fx:id="colUltimoAcceso" prefWidth="130" text="Último Acceso" />
                    <TableColumn fx:id="colEstado" prefWidth="80" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay usuarios registrados" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- FORMULARIO DE USUARIO -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="👤 Datos del Usuario" />

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33" />
                    <ColumnConstraints percentWidth="33" />
                    <ColumnConstraints percentWidth="34" />
                </columnConstraints>

                <!-- Fila 0: Usuario | Nombre Completo | Email -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="👤 Usuario *" />
                    <TextField fx:id="txtNombreUsuario" prefHeight="34" promptText="Ingrese nombre de usuario..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📝 Nombre Completo *" />
                    <TextField fx:id="txtNombreCompleto" prefHeight="34" promptText="Ingrese nombres y apellidos..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📧 Email *" />
                    <TextField fx:id="txtEmail" prefHeight="34" promptText="correo@ejemplo.com..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>

                <!-- Fila 1: Contraseña | Confirmar Contraseña | Cargo -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🔒 Contraseña *" />
                    <PasswordField fx:id="txtContrasena" prefHeight="34" promptText="Mínimo 4 caracteres..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🔒 Confirmar Contraseña *" />
                    <PasswordField fx:id="txtConfirmarContrasena" prefHeight="34" promptText="Repita la contraseña..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💼 Cargo *" />
                    <ComboBox fx:id="cmbCargo" prefHeight="34" promptText="Seleccionar cargo..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>

                <!-- Fila 2: Teléfono | Estado | Fecha Registro -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📞 Teléfono" />
                    <TextField fx:id="txtTelefono" prefHeight="34" promptText="Opcional..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📌 Estado *" />
                    <ComboBox fx:id="cmbEstado" prefHeight="34" promptText="Seleccionar estado..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📅 Fecha Registro" />
                    <DatePicker fx:id="dateFechaRegistro" prefHeight="34" promptText="Fecha de registro..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- BARRA DE ACCIONES -->
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 28 14 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, -2, 0);">
            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="* Campos obligatorios" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnConsultar" onAction="#abrirConsulta" prefHeight="40" prefWidth="130" styleClass="btn-primary" text="Consultar" />
            <Button fx:id="btnLimpiar" onAction="#limpiarCampos" prefHeight="40" prefWidth="120" styleClass="btn-secondary" text="Limpiar" />
            <Button fx:id="btnEliminar" onAction="#eliminarUsuario" prefHeight="40" prefWidth="130" styleClass="btn-danger" text="Eliminar" />
            <Button fx:id="btnEditar" onAction="#editarUsuario" prefHeight="40" prefWidth="130" styleClass="btn-success" text="Editar" />
            <Button fx:id="btnGuardar" onAction="#guardarUsuario" prefHeight="40" prefWidth="180" styleClass="btn-primary" text="Guardar" />
        </HBox>
    </VBox>
</ScrollPane>