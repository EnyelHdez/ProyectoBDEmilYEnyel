<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20" style="-fx-background-color: linear-gradient(to bottom, #667eea 0%, #764ba2 100%);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.MenuPrincipalController">
    <children>
        <!-- Logo/Título -->
        <Label text=" Farmacia Kenia Carmen" textFill="WHITE">
            <font>
                <Font name="System Bold" size="42.0" />
            </font>
        </Label>

        <Label text="Sistema de Gestión " textFill="#E0E0E0">
            <font>
                <Font name="System" size="20.0" />
            </font>
        </Label>

        <!-- Espaciador -->
        <VBox prefHeight="30.0" />

        <!-- Botones del menú -->
        <VBox alignment="CENTER" spacing="18" style="-fx-padding: 40;">
            <children>
                <Button fx:id="btnProveedores" onAction="#abrirProveedores" prefHeight="55.0" prefWidth="350.0" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text=" Gestión de Proveedores" />

                <Button fx:id="btnProductos" onAction="#abrirProductos" prefHeight="55.0" prefWidth="350.0" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text=" Gestión de Productos" />

                <Button fx:id="btnOrdenCompra" onAction="#abrirOrdenCompra" prefHeight="55.0" prefWidth="350.0" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text=" Orden de Compra" />

                <Button fx:id="btnRegistroCompra" onAction="#abrirRegistroCompra" prefHeight="55.0" prefWidth="350.0" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text=" Registrar Compra" />

                <Button fx:id="btnRegistroPago" onAction="#abrirRegistroPago" prefHeight="55.0" prefWidth="350.0" style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text=" Registro de Pagos" />

                <!-- Espaciador pequeño -->
                <VBox prefHeight="10.0" />

                <Button fx:id="btnSalir" onAction="#salir" prefHeight="55.0" prefWidth="350.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 3);" text=" Salir del Sistema" />
            </children>
        </VBox>

        <!-- Footer -->
        <Label text="v1.0 - 2025" textFill="#B0B0B0">
            <font>
                <Font size="12.0" />
            </font>
        </Label>
    </children>
</VBox>
