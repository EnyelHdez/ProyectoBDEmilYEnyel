<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15" style="-fx-background-color: #EEF4FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroUsuarioController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);" prefWidth="450">

        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Registro de Usuario" />

        <Label style="-fx-font-size: 12px; -fx-text-fill: #7FA8C9;" text="Complete todos los campos para registrarse" />

        <Separator />

        <GridPane hgap="15" vgap="12">
            <columnConstraints>
                <ColumnConstraints percentWidth="35" />
                <ColumnConstraints percentWidth="65" />
            </columnConstraints>

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Usuario *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtNombreUsuario" promptText="Nombre de usuario" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Contraseña *" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <PasswordField fx:id="txtContrasena" promptText="Mínimo 4 caracteres" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Confirmar *" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <PasswordField fx:id="txtConfirmarContrasena" promptText="Repita la contraseña" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Nombre Completo *" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="txtNombreCompleto" promptText="Nombres y apellidos" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Email *" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="txtEmail" promptText="correo@ejemplo.com" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Cargo *" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <ComboBox fx:id="cmbCargo" promptText="Seleccione" prefHeight="35" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Teléfono" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <TextField fx:id="txtTelefono" promptText="Opcional" GridPane.columnIndex="1" GridPane.rowIndex="6" />

            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>

        <Label fx:id="lblError" style="-fx-font-size: 12px;" visible="false" />

        <Separator />

        <HBox alignment="CENTER" spacing="15">
            <Button fx:id="btnCancelar" onAction="#cancelar" prefHeight="35" prefWidth="120" style="-fx-background-color: white; -fx-text-fill: #6b7280; -fx-font-weight: bold; -fx-border-color: #d1d5db; -fx-border-radius: 8; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancelar" />
            <Button fx:id="btnRegistrar" onAction="#registrar" prefHeight="35" prefWidth="120" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Registrarse" />
        </HBox>

    </VBox>

</VBox>