<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<Pane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="920.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroProveedorController">
    <children>
        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="DODGERBLUE" height="44.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="920.0" />
        <Label layoutX="25.0" layoutY="6.0" prefHeight="33.0" prefWidth="187.0" text="FarmaciaKeniaCarmen" textFill="WHITE">
            <font>
                <Font name="Broadway" size="14.0" />
            </font>
        </Label>
        <Label layoutX="650.0" layoutY="6.0" prefHeight="33.0" prefWidth="250.0" text="Gestión de Proveedores" textFill="WHITE">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <!-- NUEVA SECCIÓN: Panel de búsqueda y tabla -->
        <VBox layoutX="40.0" layoutY="60.0" prefWidth="840.0" spacing="10"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="🔍 Buscar Proveedor" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                <HBox spacing="10">
                    <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar por nombre, RNC o teléfono..." prefWidth="500.0" prefHeight="30.0" />
                        <Button text="Buscar" onAction="#buscarProveedor" prefWidth="100.0" prefHeight="30.0"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                        <Button text="Mostrar Todos" onAction="#mostrarTodos" prefWidth="120.0" prefHeight="30.0"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                    </children>
                </HBox>

                <TableView fx:id="tblProveedores" prefHeight="150.0">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                        <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200" />
                        <TableColumn fx:id="colRnc" text="RNC" prefWidth="120" />
                        <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120" />
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="180" />
                        <TableColumn fx:id="colDireccion" text="Dirección" prefWidth="168" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <!-- Formulario original -->
        <VBox alignment="TOP_CENTER" layoutX="40.0" layoutY="340.0" prefHeight="280.0" prefWidth="840.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="Información del Proveedor" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>

                <GridPane hgap="15.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="230.0" minWidth="10.0" prefWidth="150.0" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="334.0" minWidth="10.0" prefWidth="320.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Nombre/Razón Social:">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <TextField fx:id="txtNombre" promptText="Nombre de la empresa" GridPane.columnIndex="1" />

                        <Label text="RNC / Cédula:" GridPane.rowIndex="1">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <TextField fx:id="txtRNC" promptText="000-00000-0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Teléfono de Contacto:" GridPane.rowIndex="2">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <TextField fx:id="txtTelefono" promptText="809-000-0000" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Correo Electrónico:" GridPane.rowIndex="3">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <TextField fx:id="txtEmail" promptText="contacto@proveedor.com" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Dirección Física:" GridPane.rowIndex="4">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <TextField fx:id="txtDireccion" promptText="Calle, Número, Ciudad" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                    </children>
                </GridPane>

                <Separator prefWidth="200.0" />

                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNuevo" onAction="#nuevoProveedor" mnemonicParsing="false" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #9b59b6; -fx-cursor: hand;" text="Nuevo" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnGuardar" onAction="#guardarProveedor" mnemonicParsing="false" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #27ae60; -fx-cursor: hand;" text="Guardar" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnEditar" onAction="#editarProveedor" mnemonicParsing="false" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #f39c12; -fx-cursor: hand;" text="Editar" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnEliminar" onAction="#eliminarProveedor" mnemonicParsing="false" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #e74c3c; -fx-cursor: hand;" text="Eliminar" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                        <Button fx:id="btnLimpiar" onAction="#limpiarCampos" mnemonicParsing="false" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #95a5a6; -fx-cursor: hand;" text="Limpiar" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</Pane>