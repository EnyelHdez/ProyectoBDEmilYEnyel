<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="0"
      style="-fx-background-color: #f0f2f5;"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.proyecto.Controladores.RegistroProveedorController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT"
          prefHeight="50"
          style="-fx-background-color: #1E90FF; -fx-padding: 0 20 0 20;">
        <Label text="Farmacia Kenia Carmen" textFill="WHITE" HBox.hgrow="ALWAYS">
            <font><Font size="15" /></font>
        </Label>
        <Label text="Gestión de Proveedores" textFill="WHITE">
            <font><Font size="15" /></font>
        </Label>
    </HBox>

    <VBox spacing="14" style="-fx-padding: 18;">

        <!-- BUSCADOR -->
        <VBox spacing="10"
              style="-fx-background-color: white; -fx-padding: 14 18 14 18; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-border-width: 0.5;">
            <Label text="Buscar proveedor" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar" prefWidth="480" prefHeight="34"
                           promptText="Buscar por nombre, RNC, teléfono o dirección..."
                           style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                <Button text="Buscar" onAction="#buscarProveedor" prefHeight="34"
                        style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #1E90FF; -fx-text-fill: #1E90FF; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 14 0 14;" />
                <Button text="Mostrar todos" onAction="#mostrarTodos" prefHeight="34"
                        style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-text-fill: #6b7280; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 14 0 14;" />
            </HBox>
        </VBox>

        <!-- TABLA -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-border-width: 0.5;">
            <TableView fx:id="tblProveedores" prefHeight="200" prefWidth="860"
                       style="-fx-background-color: transparent; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="colId"              prefWidth="45"  text="ID" />
                    <TableColumn fx:id="colRazonSocial"     prefWidth="130" text="Razón Social" />
                    <TableColumn fx:id="colNombreComercial" prefWidth="120" text="Nombre Comercial" />
                    <TableColumn fx:id="colRnc"             prefWidth="100" text="RNC" />
                    <TableColumn fx:id="colTelefono"        prefWidth="95"  text="Teléfono" />
                    <TableColumn fx:id="colEmail"           prefWidth="140" text="Email" />
                    <TableColumn fx:id="colContacto"        prefWidth="95"  text="Contacto" />
                    <TableColumn fx:id="colDireccion"       prefWidth="160" text="Dirección" />
                    <TableColumn fx:id="colEstado"          prefWidth="65"  text="Estado" />
                </columns>
            </TableView>
        </VBox>

        <!-- FORMULARIO -->
        <VBox spacing="14"
              style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-border-width: 0.5;">

            <Label text="Información del proveedor"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827; -fx-padding: 0 0 6 0; -fx-border-color: transparent transparent #e5e7eb transparent; -fx-border-width: 0 0 0.5 0;" />

            <GridPane hgap="20" vgap="12" prefWidth="860">
                <columnConstraints>
                    <ColumnConstraints prefWidth="420" />
                    <ColumnConstraints prefWidth="420" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints prefHeight="56" />
                    <RowConstraints prefHeight="56" />
                    <RowConstraints prefHeight="56" />
                    <RowConstraints prefHeight="56" />
                    <RowConstraints prefHeight="56" />
                </rowConstraints>

                <!-- FILA 0: Razón Social | Nombre Comercial -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Razón social" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtNombre" prefHeight="34"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Nombre comercial" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtNombreComercial" prefHeight="34"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>

                <!-- FILA 1: RNC | Teléfono -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="RNC" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtRNC" prefHeight="34"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Teléfono" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtTelefono" prefHeight="34"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>

                <!-- FILA 2: Email | Contacto -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="Email" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtEmail" prefHeight="34"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label text="Contacto" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtContacto" prefHeight="34"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>

                <!-- FILA 3: Dirección (ancho completo) -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                    <Label text="Dirección" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" />
                    <TextField fx:id="txtDireccion" prefHeight="34" prefWidth="860"
                               promptText="Ej: Calle Principal #5, Santiago"
                               style="-fx-font-size: 13px; -fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #d1d5db; -fx-border-width: 0.5;" />
                </VBox>

                <!-- FILA 4: Estado -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="4" alignment="BOTTOM_LEFT">
                    <CheckBox fx:id="chkEstado" text="Activo"
                              style="-fx-font-size: 13px; -fx-text-fill: #111827; -fx-padding: 0 0 6 0;" />
                </VBox>

            </GridPane>

            <Separator prefWidth="860" />

            <!-- BOTONES -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="Guardar" onAction="#guardarProveedor" prefHeight="34"
                        style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #1E90FF; -fx-text-fill: white; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" />
                <Button text="Editar" onAction="#editarProveedor" prefHeight="34"
                        style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-text-fill: #111827; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" />
                <Button text="Eliminar" onAction="#eliminarProveedor" prefHeight="34"
                        style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #f87171; -fx-text-fill: #dc2626; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" />
                <Button text="Limpiar" onAction="#limpiarCampos" prefHeight="34"
                        style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-text-fill: #6b7280; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" />
            </HBox>

        </VBox>
    </VBox>
</VBox>
