<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox spacing="16" style="-fx-padding: 22 28 10 28; -fx-background-color: #EEF4FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.CatalogoProductosController">

    <!-- TÍTULO -->
    <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label style="-fx-font-size: 24px;" text="📦" />
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Catálogo de Productos" />
            <Rectangle fill="#D6E8F5" height="24" width="1" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Consulta de productos disponibles" />
        </HBox>
        <Separator />
        <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="Modo consulta - Solo lectura" />
    </VBox>

    <!-- FILTROS DE BÚSQUEDA -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 15 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍 Buscar Productos" />
        <HBox spacing="10">
            <TextField fx:id="txtBuscar" prefHeight="36" HBox.hgrow="ALWAYS" promptText="Buscar por nombre o categoría..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
            <Button fx:id="btnBuscar" onAction="#buscarProducto" prefHeight="36" prefWidth="90" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Buscar" />
            <Button fx:id="btnVerTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" style="-fx-background-color: #EEF4FB; -fx-text-fill: #1A6BAD; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Ver todos" />
        </HBox>

        <!-- FILTROS ADICIONALES -->
        <HBox spacing="10">
            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Filtrar por:" />
            <ComboBox fx:id="cmbCategoria" prefHeight="30" prefWidth="180" promptText="Categoría" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 12px;" />
            <ComboBox fx:id="cmbEstado" prefHeight="30" prefWidth="120" promptText="Estado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblTotalRegistros" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="Total: 0 productos" />
        </HBox>
    </VBox>

    <!-- TABLA DE PRODUCTOS -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <TableView fx:id="tblProductos" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colNombre" prefWidth="250" text="Producto" />
                    <TableColumn fx:id="colCategoria" prefWidth="150" text="Categoría" />
                    <TableColumn fx:id="colPrecioVenta" prefWidth="120" text="Precio (RD$)" />
                    <TableColumn fx:id="colStock" prefWidth="80" text="Stock" />
                    <TableColumn fx:id="colEstado" prefWidth="100" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay productos disponibles" />
                </placeholder>
            </TableView>
        </ScrollPane>
    </VBox>

    <!-- BARRA DE INFORMACIÓN -->
    <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-background-color: white; -fx-padding: 12 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, -2, 0);">
        <Label style="-fx-font-size: 10px; -fx-text-fill: #9BBDD6;" text="💡 Catálogo de productos - Solo lectura" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="lblStockTotal" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="📦 Stock total: 0 unidades" />
        <Label fx:id="lblProductosActivos" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="✅ Productos activos: 0" />
    </HBox>
</VBox>