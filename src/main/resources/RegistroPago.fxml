<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="650.0" prefWidth="739.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroPagoController">
    <children>

        <Rectangle fill="#667eea" height="650.0" layoutX="-2.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="129.0" />

        <Rectangle fill="#667eea" height="67.0" layoutX="126.0" stroke="#5568d3" width="613.0" />
        <Label layoutX="150.0" layoutY="16.0" text="Farmacia Kenia Carmen - Pago" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <!-- NUEVA SECCIÓN: Tabla de búsqueda -->
        <VBox layoutX="150.0" layoutY="80.0" prefWidth="562.0" spacing="10">
            <children>
                <HBox spacing="10">
                    <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar pago..." prefWidth="300.0" />
                        <Button text="Buscar" onAction="#buscarPago" prefWidth="80.0"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" />
                        <Button text="Todos" onAction="#mostrarTodos" prefWidth="80.0"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" />
                    </children>
                </HBox>

                <TableView fx:id="tblPagos" prefHeight="120.0">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40" />
                        <TableColumn fx:id="colProveedor" text="Proveedor" prefWidth="140" />
                        <TableColumn fx:id="colNumFactura" text="N° Factura" prefWidth="90" />
                        <TableColumn fx:id="colFechaPago" text="Fecha" prefWidth="90" />
                        <TableColumn fx:id="colMetodoPago" text="Método" prefWidth="100" />
                        <TableColumn fx:id="colMonto" text="Monto" prefWidth="80" />
                        <TableColumn fx:id="colEstado" text="Estado" prefWidth="80" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <VBox layoutX="150.0" layoutY="240.0" prefWidth="562.0" spacing="18.0">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 20px;" />
                        <Label text="Registro de Pago a Proveedor">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>

                <GridPane hgap="15.0" prefHeight="169.0" prefWidth="418.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="120.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="180.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="120.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="35.0" prefHeight="35.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>

                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Proveedor:" />
                        <ComboBox fx:id="cmbProveedor" prefWidth="180.0" promptText="Seleccione proveedor" style="-fx-background-radius: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 6;" GridPane.columnIndex="1" />

                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="N° Factura:" GridPane.columnIndex="2" />
                        <TextField fx:id="txtNumFactura" promptText="FAC-00000" style="-fx-background-radius: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 6;" GridPane.columnIndex="3" />

                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Fecha Factura:" GridPane.rowIndex="1" />
                        <DatePicker fx:id="dateFechaFactura" prefHeight="27.0" prefWidth="154.0" promptText="Seleccione fecha" style="-fx-background-radius: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Fecha Pago:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                        <DatePicker fx:id="dateFechaPago" prefWidth="100.0" promptText="Hoy" style="-fx-background-radius: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 6;" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Método Pago:" GridPane.rowIndex="2" />
                        <ComboBox fx:id="cmbMetodoPago" prefWidth="180.0" promptText="Forma de pago" style="-fx-background-radius: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 6;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="Monto (RD$):" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <TextField fx:id="txtMonto" promptText="0.00" onKeyReleased="#calcularTotal" style="-fx-background-radius: 6; -fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="12.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="27.0" prefWidth="552.0" spacing="20">
                            <children>
                                <Label style="-fx-font-size: 16px;" />
                                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #34495e;" text="Total a Pagar:" />
                                <Label fx:id="lblTotalPagar" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #27ae60;" text="RD$ 0.00" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" text="Estado:" />
                                <Label fx:id="lblEstado" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #f39c12; -fx-background-color: #fef5e7; -fx-padding: 4 10; -fx-background-radius: 12;" text="Pendiente" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox layoutX="12.0" layoutY="80.0" spacing="12.0">
            <children>
                <Button fx:id="btnNuevo" onAction="#nuevoPago" prefWidth="100.0" prefHeight="35.0" text="Nuevo Pago"
                        style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;" />
                <Button prefWidth="100.0" prefHeight="35.0" text="Historial"
                        style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-border-color: #667eea; -fx-border-width: 2;" />
            </children>
        </VBox>

        <Button fx:id="btnCancelar" onAction="#cancelar" layoutX="150.0" layoutY="580.0" mnemonicParsing="false" prefHeight="38.0" prefWidth="110.0" style="-fx-background-color: #e74c3c; -fx-background-radius: 20; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" textFill="WHITE" />

        <Button fx:id="btnRegistrarPago" onAction="#registrarPago" layoutX="279.0" layoutY="580.0" mnemonicParsing="false" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #27ae60; -fx-background-radius: 20; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(39, 174, 96, 0.4), 8, 0, 0, 2);" text="Registrar Pago" textFill="WHITE" />
    </children>
</Pane>