<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" stylesheets="@estilos.css" style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroPagoController">

    <VBox spacing="16" style="-fx-padding: 22 28 10 28; -fx-background-color: #EEF4FB;">

        <!-- TÍTULO -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 24px;" text="💳" />
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Registro de Pagos" />
                <Rectangle fill="#D6E8F5" height="24" width="1" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Complete los datos del pago" />
            </HBox>
            <Separator />
            <Label style="-fx-font-size: 11px; -fx-text-fill: #E53935;" text="* Campos obligatorios" />
        </VBox>

        <!-- PANEL DE CONSULTA (OCULTO INICIALMENTE) -->
        <VBox fx:id="consultaPanel" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 15 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" managed="false" visible="false">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍 Buscar Pagos Registrados" />
            <HBox spacing="10">
                <TextField fx:id="txtBuscar" prefHeight="36" HBox.hgrow="ALWAYS" promptText="Buscar por referencia o ID de cuenta..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                <Button fx:id="btnBuscar" onAction="#buscarPago" prefHeight="36" prefWidth="90" styleClass="btn-search" text="Buscar" />
                <Button fx:id="btnVerTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" styleClass="btn-outline" text="Ver todos" />
                <Button fx:id="btnCerrarConsulta" onAction="#cerrarConsulta" prefHeight="36" prefWidth="95" styleClass="btn-cerrar" text="Cerrar" />
            </HBox>

            <!-- TABLA DE PAGOS -->
            <TableView fx:id="tblPagos" prefHeight="200" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                    <TableColumn fx:id="colIdCuenta" prefWidth="100" text="ID Cuenta" />
                    <TableColumn fx:id="colReferencia" prefWidth="200" text="Referencia" />
                    <TableColumn fx:id="colFecha" prefWidth="180" text="Fecha y Hora" />
                    <TableColumn fx:id="colMonto" prefWidth="120" text="Monto RD$" />
                    <TableColumn fx:id="colEstado" prefWidth="90" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay pagos registrados" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- FORMULARIO DE REGISTRO/EDICIÓN -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="📝 Datos del Pago" />

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="30" />
                    <ColumnConstraints percentWidth="70" />
                </columnConstraints>

                <!-- ID Cuenta de Pago | Referencia -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🏦 ID Cuenta de Pago *" />
                    <TextField fx:id="txtIdCuentaPago" promptText="Ej: 1001" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📝 Referencia" />
                    <TextField fx:id="txtReferencia" promptText="Ej: PAG-2025-001 / Descripción del pago" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>

                <!-- Fecha | Monto -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📅 Fecha del Pago *" />
                    <DatePicker fx:id="dateFecha" maxWidth="Infinity" promptText="Seleccione fecha" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px;" />
                    <Label style="-fx-font-size: 10px; -fx-text-fill: #9BBDD6;" text="La hora se registra automáticamente" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💰 Monto (RD$) *" />
                    <TextField fx:id="txtMonto" onKeyReleased="#calcularTotal" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 15px; -fx-font-weight: bold; -fx-padding: 7 10; -fx-text-fill: #1A6BAD;" />
                </VBox>
            </GridPane>

            <!-- Estado -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: #F5F9FD; -fx-background-radius: 10; -fx-padding: 12 16; -fx-border-color: #D6E8F5; -fx-border-radius: 10;">
                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📌 Estado del Pago *" />
                <ToggleButton fx:id="tglEstado" onAction="#toggleEstado" selected="true" style="-fx-background-color: #DFF5E8; -fx-text-fill: #1A7A40; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 20; -fx-cursor: hand; -fx-padding: 6 18;" text="✔ Activo (true)" />
                <Label fx:id="lblEstadoHint" style="-fx-font-size: 11px; -fx-text-fill: #5DA87A;" text="El pago se registrará como Activo" />
            </HBox>

            <!-- BANNER TOTAL -->
            <HBox alignment="CENTER_LEFT" spacing="24" style="-fx-background-color: #EEF4FB; -fx-background-radius: 12; -fx-padding: 16 22; -fx-border-color: #BAD6EE; -fx-border-radius: 12;">
                <VBox spacing="3">
                    <Label style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #7FA8C9;" text="TOTAL A PAGAR" />
                    <Label fx:id="lblTotalPagar" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="RD$ 0.00" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT" spacing="3">
                    <Label style="-fx-font-size: 10px; -fx-text-fill: #9BBDD6;" text="Registro en edición" />
                    <Label fx:id="lblIdPagoActual" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="— Nuevo —" />
                </VBox>
            </HBox>
        </VBox>

        <!-- BARRA DE ACCIONES -->
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 28 14 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, -2, 0);">
            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="* Campos obligatorios" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnConsultar" onAction="#abrirConsulta" prefHeight="40" prefWidth="130" styleClass="btn-primary" text="Consultar" />
            <Button fx:id="btnCancelar" onAction="#cancelar" prefHeight="40" prefWidth="110" styleClass="btn-secondary" text="Cancelar" />
            <Button fx:id="btnEliminar" onAction="#eliminarPago" prefHeight="40" prefWidth="120" styleClass="btn-danger" text="Eliminar" />
            <Button fx:id="btnEditar" onAction="#editarPago" prefHeight="40" prefWidth="120" styleClass="btn-success" text="Editar" />
            <Button fx:id="btnRegistrarPago" onAction="#registrarPago" prefHeight="40" prefWidth="170" styleClass="btn-primary" text="Guardar" />
        </HBox>
    </VBox>
</ScrollPane>