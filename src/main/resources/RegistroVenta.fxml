<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #EEF4FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroVentaController">

    <!-- SIDEBAR IZQUIERDO -->
    <left>
        <VBox minWidth="200.0" prefWidth="200.0" spacing="0" style="-fx-background-color: #1A6BAD;">
            <VBox alignment="CENTER" spacing="6" style="-fx-padding: 30 16 24 16;">
                <Label style="-fx-font-size: 38px; -fx-text-fill: #A8D8F0;" text="💰" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #A8D8F0; -fx-font-weight: bold;" text="Farmacia" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #7BBEDE;" text="Kenia Carmen" />
            </VBox>
            <Rectangle fill="#2A85CF" height="1" />
            <Region VBox.vgrow="ALWAYS" />
            <Label style="-fx-text-fill: #3A7AAD; -fx-font-size: 10px; -fx-padding: 0 0 14 16;" text="v1.0  ·  Sistema de Ventas" />
        </VBox>
    </left>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <VBox spacing="0">
            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 16 28 16 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, 0, 2);">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Gestión de Ventas" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7FA8C9;" text="Farmacia Kenia Carmen  ·  Módulo de Ventas" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblBadgeEstado" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1A7A40; -fx-background-color: #DFF5E8; -fx-padding: 6 14; -fx-background-radius: 20;" text="● Activo" />
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="16" style="-fx-padding: 22 28 10 28;">
                    <!-- BLOQUE BÚSQUEDA -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍  Buscar Ventas" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <TextField fx:id="txtBuscar" prefHeight="36" prefWidth="400" promptText="Buscar por ID, cliente o número de factura..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                            <Button onAction="#buscarVenta" prefHeight="36" prefWidth="90" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Buscar" />
                            <Button fx:id="mostrarTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" style="-fx-background-color: #EEF4FB; -fx-text-fill: #1A6BAD; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Mostrar todos" />
                        </HBox>
                    </VBox>

                    <!-- TABLA -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
                        <TableView fx:id="tblVentas" prefHeight="200" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <columns>
                                <TableColumn fx:id="colId"            prefWidth="45"  text="ID" />
                                <TableColumn fx:id="colIdCliente"     prefWidth="110" text="Cliente" />
                                <TableColumn fx:id="colIdEmpleado"    prefWidth="100" text="Empleado" />
                                <TableColumn fx:id="colIdComprobante" prefWidth="100" text="Comprobante" />
                                <!-- COLUMNA PRODUCTO -->
                                <TableColumn fx:id="colProducto"      prefWidth="130" text="Producto" />
                                <TableColumn fx:id="colFecha"         prefWidth="120" text="Fecha" />
                                <TableColumn fx:id="colSubtotal"      prefWidth="90"  text="Subtotal" />
                                <TableColumn fx:id="colDescuento"     prefWidth="90"  text="Descuento" />
                                <TableColumn fx:id="colItbis"         prefWidth="80"  text="ITBIS" />
                                <TableColumn fx:id="colTotal"         prefWidth="90"  text="Total" />
                                <TableColumn fx:id="colEstado"        prefWidth="80"  text="Estado" />
                            </columns>
                            <placeholder>
                                <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay ventas registradas" />
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- FORMULARIO -->
                    <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 20 20 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 15px;" text="📝" />
                            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Información de la Venta" />
                            <Rectangle fill="#D6E8F5" height="16" width="1" />
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="Los campos marcados con * son obligatorios" />
                        </HBox>

                        <GridPane hgap="16" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.33" />
                                <ColumnConstraints percentWidth="33.33" />
                                <ColumnConstraints percentWidth="33.33" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints prefHeight="56" />
                                <RowConstraints prefHeight="56" />
                                <RowConstraints prefHeight="56" />
                                <RowConstraints prefHeight="56" />
                                <RowConstraints prefHeight="56" />
                            </rowConstraints>

                            <!-- FILA 0: Cliente | Empleado | Comprobante -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Cliente *" />
                                <ComboBox fx:id="cmbCliente" maxWidth="Infinity" prefHeight="34" promptText="Seleccione cliente" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Empleado *" />
                                <ComboBox fx:id="cmbEmpleado" maxWidth="Infinity" prefHeight="34" promptText="Seleccione empleado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Comprobante" />
                                <ComboBox fx:id="cmbComprobante" maxWidth="Infinity" prefHeight="34" promptText="Seleccione comprobante" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>

                            <!-- FILA 1: Producto (fila propia, ancho completo) -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="1">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💊  Producto" />
                                <ComboBox fx:id="cmbProducto" maxWidth="Infinity" prefHeight="34" promptText="Seleccione un producto" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>

                            <!-- FILA 2: Fecha | Estado -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Fecha *" />
                                <DatePicker fx:id="dateFecha" maxWidth="Infinity" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Estado *" />
                                <ComboBox fx:id="cmbEstado" maxWidth="Infinity" prefHeight="34" promptText="Seleccione estado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>

                            <!-- FILA 3: Subtotal | Descuento | ITBIS -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Subtotal (RD$) *" />
                                <TextField fx:id="txtSubtotal" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Descuento (RD$)" />
                                <TextField fx:id="txtDescuento" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="3">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="ITBIS (RD$)" />
                                <TextField fx:id="txtItbis" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                            </VBox>

                            <!-- FILA 4: Total -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="4">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Total (RD$) *" />
                                <TextField fx:id="txtTotal" prefHeight="40" promptText="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-text-fill: #1A6BAD;" />
                            </VBox>
                        </GridPane>

                        <Separator />

                        <!-- BOTONES -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Button onAction="#guardarVenta" prefHeight="34" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #1E90FF; -fx-text-fill: white; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Guardar" />
                            <Button onAction="#editarVenta" prefHeight="34" style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-text-fill: #111827; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Editar" />
                            <Button onAction="#eliminarVenta" prefHeight="34" style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #f87171; -fx-text-fill: #dc2626; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Eliminar" />
                            <Button onAction="#limpiarCampos" prefHeight="34" style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-text-fill: #6b7280; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Limpiar" />
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
