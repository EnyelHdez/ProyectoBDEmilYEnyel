<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" stylesheets="@estilos.css" style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroVentaController">

    <VBox spacing="16" style="-fx-padding: 22 28 10 28; -fx-background-color: #EEF4FB;">

        <!-- TÍTULO -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 24px;" text="💰" />
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Registro de Ventas" />
                <Rectangle fill="#D6E8F5" height="24" width="1" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Complete los datos de la venta" />
            </HBox>
            <Separator />
            <Label style="-fx-font-size: 11px; -fx-text-fill: #E53935;" text="* Campos obligatorios" />
        </VBox>

        <!-- PANEL DE CONSULTA (OCULTO INICIALMENTE) -->
        <VBox fx:id="consultaPanel" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 15 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" managed="false" visible="false">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍 Buscar Ventas" />
            <HBox spacing="10">
                <TextField fx:id="txtBuscar" prefHeight="36" HBox.hgrow="ALWAYS" promptText="Buscar por ID, cliente, producto o estado..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                <Button fx:id="btnBuscar" onAction="#buscarVenta" prefHeight="36" prefWidth="90" styleClass="btn-search" text="Buscar" />
                <Button fx:id="btnVerTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" styleClass="btn-outline" text="Ver todos" />
                <Button fx:id="btnCerrarConsulta" onAction="#cerrarConsulta" prefHeight="36" prefWidth="95" styleClass="btn-cerrar" text="✖ Cerrar" />
            </HBox>

            <!-- TABLA DE VENTAS -->
            <TableView fx:id="tblVentas" prefHeight="350" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colIdCliente" prefWidth="100" text="ID Cliente" />
                    <TableColumn fx:id="colIdEmpleado" prefWidth="100" text="ID Empleado" />
                    <TableColumn fx:id="colIdComprobante" prefWidth="100" text="ID Comprobante" />
                    <TableColumn fx:id="colProducto" prefWidth="150" text="Producto" />
                    <TableColumn fx:id="colFecha" prefWidth="120" text="Fecha" />
                    <TableColumn fx:id="colSubtotal" prefWidth="90" text="Subtotal" />
                    <TableColumn fx:id="colDescuento" prefWidth="90" text="Descuento" />
                    <TableColumn fx:id="colItbis" prefWidth="80" text="ITBIS" />
                    <TableColumn fx:id="colTotal" prefWidth="90" text="Total" />
                    <TableColumn fx:id="colEstado" prefWidth="90" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay ventas registradas" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- FORMULARIO DE REGISTRO/EDICIÓN -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="📝 Datos de la Venta" />

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                </columnConstraints>

                <!-- Fila 0: Cliente | Empleado | Comprobante -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="👤 Cliente" />
                    <ComboBox fx:id="cmbCliente" maxWidth="Infinity" prefHeight="34" promptText="Seleccione cliente" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="👔 Empleado *" />
                    <ComboBox fx:id="cmbEmpleado" maxWidth="Infinity" prefHeight="34" promptText="Seleccione empleado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📄 Comprobante" />
                    <ComboBox fx:id="cmbComprobante" maxWidth="Infinity" prefHeight="34" promptText="Seleccione comprobante" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>

                <!-- Fila 1: Producto -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💊 Producto" />
                    <ComboBox fx:id="cmbProducto" maxWidth="Infinity" prefHeight="34" promptText="Seleccione un producto" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>

                <!-- Fila 2: Fecha | Estado -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📅 Fecha *" />
                    <DatePicker fx:id="dateFecha" maxWidth="Infinity" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📌 Estado *" />
                    <ComboBox fx:id="cmbEstado" maxWidth="Infinity" prefHeight="34" promptText="Seleccione estado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>

                <!-- Fila 3: Subtotal | Descuento | ITBIS -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💰 Subtotal (RD$) *" />
                    <TextField fx:id="txtSubtotal" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🏷️ Descuento (RD$)" />
                    <TextField fx:id="txtDescuento" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📊 ITBIS (RD$)" />
                    <TextField fx:id="txtItbis" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                </VBox>

                <!-- Fila 4: Total -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="4">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💵 Total (RD$) *" />
                    <TextField fx:id="txtTotal" prefHeight="40" promptText="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-text-fill: #1A6BAD;" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- BARRA DE ACCIONES -->
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 28 14 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, -2, 0);">
            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="* Campos obligatorios" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnConsultar" onAction="#abrirConsulta" prefHeight="40" prefWidth="130" styleClass="btn-primary" text="🔍 Consultar" />
            <Button fx:id="btnVentaConSeguro" onAction="#abrirVentaConSeguro" prefHeight="40" prefWidth="170" styleClass="btn-warning" text="🏥 Venta con Seguro" />
            <Button fx:id="btnLimpiar" onAction="#limpiarCampos" prefHeight="40" prefWidth="120" styleClass="btn-secondary" text="🧹 Limpiar" />
            <Button fx:id="btnEliminar" onAction="#eliminarVenta" prefHeight="40" prefWidth="130" styleClass="btn-danger" text="🗑 Eliminar" />
            <Button fx:id="btnEditar" onAction="#editarVenta" prefHeight="40" prefWidth="130" styleClass="btn-success" text="✏ Editar" />
            <Button fx:id="btnGuardar" onAction="#guardarVenta" prefHeight="40" prefWidth="170" styleClass="btn-primary" text="✔ Guardar" />
        </HBox>
    </VBox>
</ScrollPane>