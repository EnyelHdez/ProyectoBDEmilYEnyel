<jasperReport name="ReporteNominas" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="5901d041-5848-4c79-b869-5b534edaf949">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SQLServer"/>
	<parameter name="id_nomina" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT 
    n.id_nomina,
    n.periodo_inicio,
    n.periodo_fin,
    n.salario_bruto,
    n.bonificaciones,
    n.comisiones,
    n.deducciones_sfs,
    n.deducciones_afp,
    n.otras_deducciones,
    n.salario_neto,
    n.fecha_pago,
    n.estado,
    
    e.id_empleado,
    e.cedula,
    e.nombres,
    e.apellidos,
    e.fecha_nacimiento,
    e.sexo,
    e.telefono,
    e.email,
    e.fecha_ingreso,
    e.salario_base,
    
    c.id_cargo,
    c.nombre AS cargo_nombre,
    c.descripcion AS cargo_descripcion,
    
    d.id_direccion,
    d.numero AS direccion_numero,
    d.referencia AS direccion_referencia,
    
    CASE 
        WHEN n.estado = 'PENDIENTE' THEN 'Pendiente'
        WHEN n.estado = 'PAGADA' THEN 'Pagada'
        WHEN n.estado = 'ANULADA' THEN 'Anulada'
        ELSE n.estado
    END AS estado_descripcion,
    
    (n.salario_bruto + ISNULL(n.bonificaciones,0) + ISNULL(n.comisiones,0)) AS total_ingresos,
    (ISNULL(n.deducciones_sfs,0) + ISNULL(n.deducciones_afp,0) + ISNULL(n.otras_deducciones,0)) AS total_deducciones

FROM dbo.tbl_NOMINA n
INNER JOIN dbo.tbl_EMPLEADO e ON e.id_empleado = n.id_empleado
INNER JOIN dbo.tbl_CARGO c ON c.id_cargo = e.id_cargo
LEFT JOIN dbo.tbl_DIRECCION d ON d.id_direccion = e.id_direccion
WHERE n.id_nomina = $P{id_nomina}]]></query>
