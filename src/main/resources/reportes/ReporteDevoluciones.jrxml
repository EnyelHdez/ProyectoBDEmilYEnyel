<jasperReport name="ReporteDevoluciones" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="d4e5f6a7-b8c9-0123-defa-123456789abc">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SQLServer"/>
	<parameter name="id_devolucion" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT 
    d.id_devolucion,
    d.id_venta,
    d.fecha,
    d.monto_devuelto,
    ISNULL(d.observacion, 'Ninguna') AS observacion,
    d.estado,
    p.id_producto,
    p.nombre AS producto_nombre,
    ISNULL(p.codigo_barra, '-') AS codigo_barra,
    e.nombres + ' ' + e.apellidos AS empleado_nombre,
    ISNULL(c.nombres + ' ' + c.apellidos, 'CONSUMIDOR FINAL') AS cliente_nombre,
    m.nombre AS motivo_nombre,
    ISNULL(m.tipo, '-') AS motivo_tipo
FROM dbo.tbl_DEVOLUCION d
INNER JOIN dbo.tbl_PRODUCTO p ON p.id_producto = d.id_producto
INNER JOIN dbo.tbl_EMPLEADO e ON e.id_empleado = d.id_empleado
LEFT JOIN dbo.tbl_CLIENTE c ON c.id_cliente = d.id_cliente
INNER JOIN dbo.tbl_MOTIVO m ON m.id_motivo = d.id_motivo
WHERE d.id_devolucion = $P{id_devolucion}]]></query>
	<field name="id_devolucion" class="java.lang.Integer"/>
	<field name="id_venta" class="java.lang.Integer"/>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="monto_devuelto" class="java.math.BigDecimal"/>
	<field name="observacion" class="java.lang.String"/>
