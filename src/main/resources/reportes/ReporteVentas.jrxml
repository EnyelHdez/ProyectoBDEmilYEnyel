<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="ReporteVentas" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="abda99c1-49d0-49c5-b4ca-9f800b523416">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SQLServer"/>
	<parameter name="id_venta" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT
    v.id_venta,
    v.fecha,
    v.estado AS estado_venta,
    v.subtotal,
    v.descuento AS descuento_venta,
    v.itbis AS itbis_venta,
    v.total,
    ISNULL(c.nombres + ' ' + c.apellidos, 'CONSUMIDOR FINAL') AS cliente_nombre,
    ISNULL(c.cedula_rnc, '-') AS cliente_cedula,
    ISNULL(c.telefono, '-') AS cliente_telefono,
    ISNULL(c.email, '-') AS cliente_email,
    ISNULL(c.puntos_fidelidad, 0) AS cliente_puntos,
    e.nombres + ' ' + e.apellidos AS vendedor_nombre,
    ISNULL(cf.ncf, 'SIN NCF') AS ncf,
    ISNULL(tcf.codigo, '-') AS tipo_ncf_codigo,
    ISNULL(tcf.descripcion, '-') AS tipo_ncf_desc,
    cf.fecha_emision,
    rm.nro_receta,
    rm.nombre_medico_ext,
    dv.id_det_venta,
    p.codigo_barra,
    p.nombre AS producto_nombre,
    dv.cantidad,
    dv.precio_unitario,
    dv.descuento AS descuento_linea,
    dv.itbis AS itbis_linea,
    dv.subtotal AS subtotal_linea,
    dv.lote,
    dv.fecha_vencimiento
FROM dbo.tbl_VENTA v
INNER JOIN dbo.tbl_DETALLE_VENTA dv ON dv.id_venta = v.id_venta
INNER JOIN dbo.tbl_EMPLEADO e ON e.id_empleado = v.id_empleado
LEFT JOIN dbo.tbl_CLIENTE c ON c.id_cliente = v.id_cliente
LEFT JOIN dbo.tbl_COMPROBANTE_FISCAL cf ON cf.id_comprobante = v.id_comprobante
LEFT JOIN dbo.tbl_TIPO_COMPROBANTE_FISCAL tcf ON tcf.id_tipo_ncf = cf.id_tipo_ncf
LEFT JOIN dbo.tbl_RECETA_MEDICA rm ON rm.id_venta = v.id_venta
INNER JOIN dbo.tbl_PRODUCTO p ON p.id_producto = dv.id_producto
WHERE v.id_venta = $P{id_venta}
  AND v.estado NOT IN ('ANULADA')
ORDER BY dv.id_det_venta]]></query>
