<!-- Created with Jaspersoft Studio version 7.0.6.final using JasperReports Library version 7.0.6-5d2a603fdc6b3db8f842a83383e594f41891534d  -->
<jasperReport name="ReporteOrdenCompra" language="java" pageWidth="595" pageHeight="842" whenNoDataType="AllSectionsNoDetail" columnWidth="535" leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" uuid="32ee2f4a-32af-47b4-9557-d249e8af600e">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="SQLServer"/>
	<parameter name="id_orden" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<query language="SQL"><![CDATA[SELECT 
    oc.id_orden,
    oc.fecha_orden,
    oc.fecha_entrega,
    oc.condicion_pago,
    oc.observaciones,
    oc.subtotal,
    oc.total,
    oc.estado,
    oc.cantidad_productos,
    
    p.id_proveedor,
    p.rnc,
    p.razon_social,
    p.nombre_comercial,
    p.telefono AS proveedor_telefono,
    p.email AS proveedor_email,
    p.contacto AS proveedor_contacto,
    p.direccion AS proveedor_direccion,
    
    e.id_empleado,
    e.nombres + ' ' + e.apellidos AS empleado_nombre,
    e.cedula AS empleado_cedula,
    e.telefono AS empleado_telefono,
    car.nombre AS empleado_cargo,
    
    doc.id_detalle,
    doc.id_producto,
    doc.cantidad,
    doc.precio_unitario,
    doc.subtotal AS subtotal_producto,
    
    prod.nombre AS producto_nombre,
    prod.codigo_barra
    
FROM dbo.tbl_ORDEN_COMPRA oc
INNER JOIN dbo.tbl_PROVEEDOR p ON p.id_proveedor = oc.id_proveedor
INNER JOIN dbo.tbl_EMPLEADO e ON e.id_empleado = oc.id_empleado
INNER JOIN dbo.tbl_CARGO car ON car.id_cargo = e.id_cargo
INNER JOIN dbo.tbl_DETALLE_ORDEN_COMPRA doc ON doc.id_orden = oc.id_orden
INNER JOIN dbo.tbl_PRODUCTO prod ON prod.id_producto = doc.id_producto
WHERE oc.id_orden = $P{id_orden}
ORDER BY doc.id_detalle]]></query>
