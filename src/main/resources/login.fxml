<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER" spacing="0" style="-fx-background-color: linear-gradient(to bottom right, #f0f4f8, #d9e2ec, #bcccd9);" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.LoginController">

    <padding>
        <Insets bottom="50" left="50" right="50" top="50" />
    </padding>

    <!-- Tarjeta Principal - Efecto Vidrio -->
    <HBox alignment="CENTER" maxWidth="900" minWidth="850" style="-fx-background-color: rgba(255,255,255,0.7); -fx-background-radius: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 30, 0, 0, 15);">

        <!-- LADO IZQUIERDO: MARCA -->
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: transparent; -fx-padding: 50 40 50 40;" minWidth="350" prefWidth="380">

            <!-- Círculo decorativo con ícono -->
            <StackPane style="-fx-background-color: #ffffff; -fx-background-radius: 100; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(44,90,122,0.15), 15, 0, 0, 6);">
                <Label style="-fx-font-size: 60px;" text="💊" />
            </StackPane>

            <!-- Nombre de la farmacia -->
            <VBox spacing="6" alignment="CENTER">
                <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c4e6e;" text="Kenia Carmen" />
                <Label style="-fx-font-size: 14px; -fx-font-weight: normal; -fx-text-fill: #6b8da8;" text="FARMACIA PROFESIONAL" />
                <Rectangle fill="#a3b8cc" height="1" width="50" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #8aa9c2; -fx-font-style: italic;" text="“Cuidando de ti y los tuyos”" />
            </VBox>

            <!-- Detalle decorativo inferior -->
            <Label style="-fx-font-size: 10px; -fx-text-fill: #a0bbcf;" text="SISTEMA DE GESTIÓN INTEGRAL" />

        </VBox>

        <!-- SEPARADOR VERTICAL ELEGANTE -->
        <Rectangle fill="#d0dfec" width="1" height="250" />

        <!-- LADO DERECHO: ACCESO -->
        <VBox alignment="CENTER" spacing="30" style="-fx-background-color: transparent; -fx-padding: 50 45 50 45;" minWidth="400" prefWidth="430">

            <VBox spacing="8" alignment="CENTER">
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c4e6e;" text="Inicio de Sesión" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #7a9bb3;" text="Ingrese sus credenciales para continuar" />
            </VBox>

            <!-- Formulario -->
            <VBox spacing="20" maxWidth="320">

                <!-- Campo Usuario -->
                <VBox spacing="6">
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #5a7e99;" text="👤  USUARIO" />
                    <TextField fx:id="txtUsuario" promptText="ej. farmaceutico" prefHeight="44" style="-fx-background-radius: 30; -fx-border-color: #c5d5e3; -fx-border-radius: 30; -fx-font-size: 13px; -fx-padding: 0 20; -fx-background-color: rgba(255,255,255,0.9);" />
                </VBox>

                <!-- Campo Contraseña -->
                <VBox spacing="6">
                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #5a7e99;" text="🔒  CONTRASEÑA" />
                    <PasswordField fx:id="txtContrasena" promptText="••••••••" prefHeight="44" style="-fx-background-radius: 30; -fx-border-color: #c5d5e3; -fx-border-radius: 30; -fx-font-size: 14px; -fx-padding: 0 20; -fx-background-color: rgba(255,255,255,0.9);" />
                </VBox>

                <!-- Mensaje de error -->
                <Label fx:id="lblError" style="-fx-text-fill: #d95c5c; -fx-font-size: 11px; -fx-font-weight: bold;" visible="false" text="⚠ Usuario o contraseña incorrectos" />

                <!-- Botón Ingresar -->
                <Button fx:id="btnLogin" onAction="#login" prefHeight="46" prefWidth="320" styleClass="btn-primary" text="INICIAR SESION" />

            </VBox>

            <!-- Pie de página derecho -->
            <Label style="-fx-font-size: 10px; -fx-text-fill: #95aec5;" text="© 2024 Farmacia Kenia Carmen" />

        </VBox>

    </HBox>

</HBox>