<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #EEF4FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.OrdenCompraController">

    <!-- SIDEBAR IZQUIERDO -->
    <left>
        <VBox minWidth="200.0" prefWidth="200.0" spacing="0" style="-fx-background-color: #1A6BAD;">
            <VBox alignment="CENTER" spacing="6" style="-fx-padding: 30 16 24 16;">
                <Label style="-fx-font-size: 38px; -fx-text-fill: #A8D8F0;" text="📦" />
                <Label style="-fx-font-size: 13px; -fx-text-fill: #A8D8F0; -fx-font-weight: bold;" text="Farmacia" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #7BBEDE;" text="Kenia Carmen" />
            </VBox>
            <Rectangle fill="#2A85CF" height="1" />
            <VBox spacing="4" style="-fx-padding: 16 10 16 10;">
                <Button fx:id="btnNuevo" onAction="#NuevaOrden" prefHeight="42" prefWidth="180" style="-fx-background-color: #2A85CF; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="➕  Nueva Orden" />
                <Button prefHeight="42" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #A8D8F0; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="📋  Historial" />
                <Button prefHeight="42" prefWidth="180" style="-fx-background-color: transparent; -fx-text-fill: #A8D8F0; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16;" text="🏭  Proveedores" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <Label style="-fx-text-fill: #3A7AAD; -fx-font-size: 10px; -fx-padding: 0 0 14 16;" text="v1.0  ·  Sistema de Compras" />
        </VBox>
    </left>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <VBox spacing="0">
            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 16 28 16 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, 0, 2);">
                <VBox spacing="2">
                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Órdenes de Compra a Proveedores" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7FA8C9;" text="Farmacia Kenia Carmen  ·  Módulo de Compras" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblBadgeEstado" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1A7A40; -fx-background-color: #DFF5E8; -fx-padding: 6 14; -fx-background-radius: 20;" text="● Activo" />
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="16" style="-fx-padding: 22 28 10 28;">

                    <!-- BLOQUE BÚSQUEDA -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
                        <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍  Buscar Órdenes" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <TextField fx:id="txtBuscar" prefHeight="36" prefWidth="400" promptText="Buscar por ID, proveedor o estado..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                            <Button onAction="#buscarOrden" prefHeight="36" prefWidth="90" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Buscar" />
                            <Button onAction="#mostrarTodos" prefHeight="36" prefWidth="95" style="-fx-background-color: #EEF4FB; -fx-text-fill: #1A6BAD; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="Mostrar todos" />
                        </HBox>
                    </VBox>

                    <!-- TABLA DE ÓRDENES -->
                    <VBox style="-fx-background-color: white; -fx-background-radius: 14; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
                        <TableView fx:id="tblOrdenes" prefHeight="180" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="45" text="ID" />
                                <TableColumn fx:id="colProveedor" prefWidth="150" text="Proveedor" />
                                <TableColumn fx:id="colEmpleado" prefWidth="120" text="Empleado" />
                                <TableColumn fx:id="colFechaOrden" prefWidth="100" text="Fecha Orden" />
                                <TableColumn fx:id="colFechaEntrega" prefWidth="100" text="Fecha Entrega" />
                                <TableColumn fx:id="colTotal" prefWidth="100" text="Total" />
                                <TableColumn fx:id="colEstado" prefWidth="100" text="Estado" />
                            </columns>
                            <placeholder>
                                <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay órdenes registradas" />
                            </placeholder>
                        </TableView>
                    </VBox>

                    <!-- FORMULARIO -->
                    <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 20 20 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 15px;" text="📋" />
                            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Información de la Orden de Compra" />
                            <Rectangle fill="#D6E8F5" height="16" width="1" />
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="Los campos marcados con * son obligatorios" />
                        </HBox>

                        <GridPane hgap="16" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33" />
                                <ColumnConstraints percentWidth="33" />
                                <ColumnConstraints percentWidth="34" />
                            </columnConstraints>

                            <!-- FILA 0: Proveedor | Empleado | Estado -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Proveedor *" />
                                <ComboBox fx:id="cmbProveedor" prefHeight="34" promptText="Seleccione proveedor" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Empleado *" />
                                <ComboBox fx:id="cmbEmpleado" prefHeight="34" promptText="Seleccione empleado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Estado *" />
                                <ComboBox fx:id="cmbEstado" prefHeight="34" promptText="Seleccione estado" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>

                            <!-- FILA 1: Fecha Orden | Fecha Entrega | Condición Pago -->
                            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Fecha Orden *" />
                                <DatePicker fx:id="dateFechaOrden" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Fecha Entrega" />
                                <DatePicker fx:id="dateFechaEntrega" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Condición de Pago" />
                                <ComboBox fx:id="cmbCondicionPago" prefHeight="34" promptText="Seleccione condición" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                            </VBox>
                        </GridPane>

                        <!-- Observaciones -->
                        <VBox spacing="5">
                            <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Observaciones" />
                            <TextArea fx:id="txtObservaciones" prefHeight="60" promptText="Observaciones adicionales..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                        </VBox>

                        <Separator />

                        <!-- SECCIÓN DE PRODUCTOS -->
                        <VBox spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label style="-fx-font-size: 14px;" text="🛒" />
                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Productos de la Orden" />
                            </HBox>

                            <!-- Formulario para agregar producto -->
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="45" />
                                    <ColumnConstraints percentWidth="15" />
                                    <ColumnConstraints percentWidth="15" />
                                    <ColumnConstraints percentWidth="25" />
                                </columnConstraints>

                                <VBox GridPane.columnIndex="0">
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Producto" />
                                    <ComboBox fx:id="cmbProducto" prefHeight="34" promptText="Seleccione producto" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                                </VBox>
                                <VBox GridPane.columnIndex="1">
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Cantidad" />
                                    <TextField fx:id="txtCantidad" promptText="1" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                                </VBox>
                                <VBox GridPane.columnIndex="2">
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Precio Unit." />
                                    <TextField fx:id="txtPrecioUnitario" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10;" />
                                </VBox>
                                <VBox alignment="BOTTOM_CENTER" GridPane.columnIndex="3">
                                    <Button onAction="#agregarProducto" prefHeight="34" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="➕ Agregar Producto" />
                                </VBox>
                            </GridPane>

                            <!-- Tabla de productos agregados -->
                            <TableView fx:id="tblDetalleProductos" prefHeight="180" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                                <columns>
                                    <TableColumn fx:id="colProdNombre" prefWidth="250" text="Producto" />
                                    <TableColumn fx:id="colProdCantidad" prefWidth="80" text="Cantidad" />
                                    <TableColumn fx:id="colProdPrecio" prefWidth="120" text="Precio Unit." />
                                    <TableColumn fx:id="colProdSubtotal" prefWidth="120" text="Subtotal" />
                                    <TableColumn fx:id="colProdAcciones" prefWidth="80" text="Acciones" />
                                </columns>
                                <placeholder>
                                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay productos agregados" />
                                </placeholder>
                            </TableView>

                            <HBox alignment="CENTER_RIGHT">
                                <Button onAction="#eliminarProductoSeleccionado" prefHeight="30" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;" text="🗑️ Eliminar Seleccionado" />
                            </HBox>
                        </VBox>

                        <Separator />

                        <!-- Totales -->
                        <GridPane hgap="16" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50" />
                                <ColumnConstraints percentWidth="50" />
                            </columnConstraints>

                            <VBox spacing="5" GridPane.columnIndex="0">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Subtotal (RD$)" />
                                <TextField fx:id="txtSubtotal" editable="false" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-background-color: #F8FAFC;" />
                            </VBox>
                            <VBox spacing="5" GridPane.columnIndex="1">
                                <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="Total (RD$)" />
                                <TextField fx:id="txtTotal" editable="false" prefHeight="40" promptText="0.00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-padding: 7 10; -fx-text-fill: #1A6BAD; -fx-background-color: #F8FAFC;" />
                            </VBox>
                        </GridPane>

                        <Separator />

                        <!-- BOTONES -->
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Button onAction="#guardarOrden" prefHeight="34" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: #1E90FF; -fx-text-fill: white; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Guardar Orden" />
                            <Button onAction="#guardarOrden" prefHeight="34" style="-fx-font-size: 13px; -fx-background-color: #3B82F6; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="✏️ Editar Orden" />
                            <Button onAction="#cancelarOrden" prefHeight="34" style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #f87171; -fx-text-fill: #dc2626; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Cancelar Orden" />
                            <Button onAction="#limpiarCampos" prefHeight="34" style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-text-fill: #6b7280; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand; -fx-padding: 0 20 0 20;" text="Limpiar" />
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>