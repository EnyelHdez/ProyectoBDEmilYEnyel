<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="468.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.OrdenCompraController">
    <children>
        <Rectangle fill="DODGERBLUE" height="468.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" width="120.0" />

        <Rectangle fill="DODGERBLUE" height="50.0" stroke="#2e8cd9" width="650.0" />
        <Label layoutX="135.0" layoutY="12.0" text="FarmaciaKeniaCarmen - Orden de compra" textFill="WHITE">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <VBox layoutX="140.0" layoutY="70.0" prefWidth="480.0" spacing="15.0">
            <children>
                <Label text="Solicitud de Requisición a Proveedor">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>

                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Proveedor:" />
                        <ComboBox fx:id="cmbProveedor" prefWidth="250.0" promptText="Seleccione Proveedor" GridPane.columnIndex="1" />

                        <Label text="Producto:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtProducto" promptText="Nombre del medicamento" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Cantidad:" GridPane.rowIndex="2" />
                        <Spinner fx:id="spnCantidad" editable="true" prefWidth="100.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
                </GridPane>

                <HBox spacing="10">
                    <children>
                        <Button onAction="#agregarProducto" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ Agregar" />
                        <Button onAction="#eliminarProducto" prefWidth="100.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="❌ Quitar" />
                    </children>
                </HBox>

                <TableView fx:id="tblDetalles" prefHeight="150.0" prefWidth="480.0">
                    <columns>
                        <TableColumn fx:id="colProducto" prefWidth="200.0" text="Producto" />
                        <TableColumn fx:id="colCantidad" prefWidth="100.0" text="Cantidad" />
                        <TableColumn fx:id="colPrecioEst" prefWidth="100.0" text="Precio Est." />
                        <TableColumn fx:id="colSubtotal" prefWidth="78.0" text="Subtotal" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Total:" />
                        <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #27ae60;" text="RD$ 0.00" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cancelar" style="-fx-background-color: #e74c3c;" text="Cancelar" textFill="WHITE" />
                        <Button fx:id="btnEnviar" mnemonicParsing="false" onAction="#enviarRequerimiento" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #2ecc71;" text="Enviar Requerimiento" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox layoutX="10.0" layoutY="70.0" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" prefWidth="100.0" text="Nueva Compra" />
                <Button mnemonicParsing="false" prefWidth="100.0" text="Historial" />
                <Button mnemonicParsing="false" prefWidth="100.0" text="Proveedores" />
                <Region prefHeight="180.0" />
                <Button mnemonicParsing="false" prefWidth="100.0" text="Configuración">
                    <font>
                        <Font size="10.0" />
                    </font>
                </Button>
            </children>
        </VBox>
    </children>
</Pane>
