<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<Pane prefHeight="680.0" prefWidth="920.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroProductoController">
    <children>

        <Rectangle arcHeight="5.0" arcWidth="5.0" fill="DODGERBLUE" height="44.0" stroke="BLACK" strokeType="INSIDE" width="920.0" />

        <Label layoutX="357.0" layoutY="6.0" prefHeight="33.0" prefWidth="250.0"
               text="Gestión de Productos" textFill="WHITE">
            <font>
                <Font name="Broadway" size="14.0" />
            </font>
        </Label>

        <Label layoutX="25.0" layoutY="6.0" prefHeight="33.0" prefWidth="187.0"
               text="FarmaciaKeniaCarmen" textFill="WHITE">
            <font>
                <Font name="Broadway" size="14.0" />
            </font>
        </Label>

        <!-- NUEVA SECCIÓN: Panel de búsqueda y tabla -->
        <VBox layoutX="40.0" layoutY="60.0" prefWidth="840.0" spacing="10"
              style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="🔍 Buscar Producto" style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                <HBox spacing="10">
                    <children>
                        <TextField fx:id="txtBuscar" promptText="Buscar por nombre o código..." prefWidth="500.0" prefHeight="30.0" />
                        <Button text="Buscar" onAction="#buscarProducto" prefWidth="100.0" prefHeight="30.0"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                        <Button text="Mostrar Todos" onAction="#mostrarTodos" prefWidth="120.0" prefHeight="30.0"
                                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" />
                    </children>
                </HBox>

                <TableView fx:id="tblProductos" prefHeight="180.0">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40" />
                        <TableColumn fx:id="colNombre" text="Producto" prefWidth="200" />
                        <TableColumn fx:id="colCodigo" text="Código" prefWidth="100" />
                        <TableColumn fx:id="colPrecioCompra" text="P. Compra" prefWidth="90" />
                        <TableColumn fx:id="colPrecioVenta" text="P. Venta" prefWidth="90" />
                        <TableColumn fx:id="colStock" text="Stock" prefWidth="70" />
                        <TableColumn fx:id="colProveedor" text="Proveedor" prefWidth="248" />
                    </columns>
                </TableView>
            </children>
        </VBox>

        <!-- Formulario de registro -->
        <VBox layoutX="40.0" layoutY="360.0" prefWidth="840.0" spacing="15.0"
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <children>
                <Label text="Información del Producto" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

                <Separator />

                <GridPane hgap="10.0" vgap="15.0">

                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="150.0" />
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="250.0" />
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="150.0" />
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="250.0" />
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints prefHeight="35.0" />
                        <RowConstraints prefHeight="35.0" />
                        <RowConstraints prefHeight="35.0" />
                    </rowConstraints>

                    <children>

                        <Label text="Nombre del Producto:">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="txtNombre"
                                   promptText="Ej. Paracetamol"
                                   GridPane.columnIndex="1" />

                        <Label text="Código de Barras:" GridPane.columnIndex="2">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="txtCodigo"
                                   promptText="000123456"
                                   GridPane.columnIndex="3" />

                        <Label text="Precio de Compra:" GridPane.rowIndex="1">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="txtPrecioCompra"
                                   promptText="0.00"
                                   GridPane.columnIndex="1"
                                   GridPane.rowIndex="1" />

                        <Label text="Precio de Venta:" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="txtPrecioVenta"
                                   promptText="0.00"
                                   GridPane.columnIndex="3"
                                   GridPane.rowIndex="1" />

                        <Label text="Proveedor:" GridPane.rowIndex="2">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <ComboBox fx:id="cbProveedor"
                                  promptText="Seleccione proveedor"
                                  prefWidth="250.0"
                                  GridPane.columnIndex="1"
                                  GridPane.rowIndex="2" />

                        <Label text="Stock Inicial:" GridPane.columnIndex="2" GridPane.rowIndex="2">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <Spinner fx:id="spnStock"
                                 prefWidth="250.0"
                                 GridPane.columnIndex="3"
                                 GridPane.rowIndex="2" />

                    </children>
                </GridPane>

                <Separator />

                <!-- Botones de acción -->
                <HBox alignment="CENTER" spacing="15.0">
                    <children>
                        <Button fx:id="btnNuevo" onAction="#nuevoProducto" prefHeight="35.0" prefWidth="130.0"
                                style="-fx-background-color: #9b59b6; -fx-cursor: hand;"
                                text="Nuevo" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>

                        <Button fx:id="btnGuardar" onAction="#guardarProducto" prefHeight="35.0" prefWidth="130.0"
                                style="-fx-background-color: #27ae60; -fx-cursor: hand;"
                                text="Guardar" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>

                        <Button fx:id="btnEditar" onAction="#editarProducto" prefHeight="35.0" prefWidth="130.0"
                                style="-fx-background-color: #f39c12; -fx-cursor: hand;"
                                text="Editar" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>

                        <Button fx:id="btnEliminar" onAction="#eliminarProducto" prefHeight="35.0" prefWidth="130.0"
                                style="-fx-background-color: #e74c3c; -fx-cursor: hand;"
                                text="Eliminar" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>

                        <Button fx:id="btnLimpiar" onAction="#limpiarCampos" prefHeight="35.0" prefWidth="130.0"
                                style="-fx-background-color: #95a5a6; -fx-cursor: hand;"
                                text="Limpiar" textFill="WHITE">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>

    </children>
</Pane>