<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane fitToWidth="true" stylesheets="@estilos.css" style="-fx-background-color: #EEF4FB; -fx-background: #EEF4FB; -fx-border-color: transparent;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.RegistroProductoController">

    <VBox spacing="16" style="-fx-padding: 22 28 10 28; -fx-background-color: #EEF4FB;">

        <!-- TÍTULO -->
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 18 20 18 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 24px;" text="💊" />
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Registro de Productos" />
                <Rectangle fill="#D6E8F5" height="24" width="1" />
                <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Complete los datos del producto" />
            </HBox>
            <Separator />
            <Label style="-fx-font-size: 11px; -fx-text-fill: #E53935;" text="* Campos obligatorios" />
        </VBox>

        <!-- PANEL DE CONSULTA (OCULTO INICIALMENTE) -->
        <VBox fx:id="consultaPanel" spacing="10" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 15 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" managed="false" visible="false">
            <Label style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1A6BAD;" text="🔍 Buscar Productos" />
            <HBox spacing="10">
                <TextField fx:id="txtBuscar" prefHeight="36" HBox.hgrow="ALWAYS" promptText="Buscar por nombre o código de barras..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 4 10;" />
                <Button fx:id="btnBuscar" onAction="#buscarProducto" prefHeight="36" prefWidth="90" styleClass="btn-search" text="Buscar" />
                <Button fx:id="btnVerTodos" onAction="#mostrarTodos" prefHeight="36" prefWidth="95" styleClass="btn-outline" text="Ver todos" />
                <Button fx:id="btnCerrarConsulta" onAction="#cerrarConsulta" prefHeight="36" prefWidth="95" styleClass="btn-cerrar" text="✖ Cerrar" />
            </HBox>

            <!-- TABLA DE PRODUCTOS -->
            <TableView fx:id="tblProductos" prefHeight="350" style="-fx-border-color: #D6E8F5; -fx-border-radius: 8; -fx-background-radius: 8;">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                    <TableColumn fx:id="colNombre" prefWidth="200" text="Producto" />
                    <TableColumn fx:id="colCodigoBarra" prefWidth="120" text="Código" />
                    <TableColumn fx:id="colCategoria" prefWidth="130" text="Categoría" />
                    <TableColumn fx:id="colPrecioCosto" prefWidth="100" text="P. Costo" />
                    <TableColumn fx:id="colPrecioVenta" prefWidth="100" text="P. Venta" />
                    <TableColumn fx:id="colStockActual" prefWidth="80" text="Stock" />
                    <TableColumn fx:id="colStockMinimo" prefWidth="80" text="Stock Mín." />
                    <TableColumn fx:id="colProveedor" prefWidth="150" text="Proveedor" />
                    <TableColumn fx:id="colRequiereReceta" prefWidth="80" text="Receta" />
                    <TableColumn fx:id="colAplicaItbis" prefWidth="70" text="ITBIS" />
                    <TableColumn fx:id="colEstado" prefWidth="80" text="Estado" />
                </columns>
                <placeholder>
                    <Label style="-fx-text-fill: #9BBDD6; -fx-font-size: 13px;" text="No hay productos registrados" />
                </placeholder>
            </TableView>
        </VBox>

        <!-- FORMULARIO DE REGISTRO/EDICIÓN -->
        <VBox spacing="14" style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.07), 8, 0, 0, 2);" VBox.vgrow="ALWAYS">

            <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="📦 Datos del Producto" />

            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                    <ColumnConstraints percentWidth="33.33" />
                </columnConstraints>

                <!-- Fila 0: Nombre | Código barra | Descripción -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📛 Nombre del producto *" />
                    <TextField fx:id="txtNombre" promptText="Ej: Paracetamol 500mg" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📊 Código de barra" />
                    <TextField fx:id="txtCodigoBarra" promptText="Ej: 000123456" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📝 Descripción" />
                    <TextField fx:id="txtDescripcion" promptText="Descripción breve..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>

                <!-- Fila 1: Precio Costo | Precio Venta | % ITBIS -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💰 Precio de costo (RD$) *" />
                    <TextField fx:id="txtPrecioCosto" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="💵 Precio de venta (RD$) *" />
                    <TextField fx:id="txtPrecioVenta" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="1">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📈 ITBIS (%)" />
                    <TextField fx:id="txtPorcentajeItbis" promptText="0.00" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px; -fx-padding: 7 10;" />
                </VBox>

                <!-- Fila 2: Categoría | Proveedor | Stock Actual -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📂 Categoría *" />
                    <ComboBox fx:id="cbCategoria" prefHeight="34" promptText="Seleccione categoría..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="🏢 Proveedor" />
                    <ComboBox fx:id="cbProveedor" prefHeight="34" promptText="Seleccione proveedor..." style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8; -fx-font-size: 13px;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📦 Stock actual *" />
                    <Spinner fx:id="spnStockActual" editable="true" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>

                <!-- Fila 3: Stock Mínimo | Checkboxes | Estado -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="⚠️ Stock mínimo" />
                    <Spinner fx:id="spnStockMinimo" editable="true" prefHeight="34" style="-fx-background-radius: 8; -fx-border-color: #BAD6EE; -fx-border-radius: 8;" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="⚙️ Opciones" />
                    <VBox spacing="8">
                        <CheckBox fx:id="chkAplicaItbis" style="-fx-font-size: 13px;" text="💰 Aplica ITBIS" />
                        <CheckBox fx:id="chkRequiereReceta" style="-fx-font-size: 13px;" text="📋 Requiere receta" />
                    </VBox>
                </VBox>
                <VBox alignment="CENTER_LEFT" spacing="5" GridPane.columnIndex="2" GridPane.rowIndex="3">
                    <Label style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4A7FA5;" text="📌 Estado" />
                    <CheckBox fx:id="chkEstado" selected="true" style="-fx-font-size: 13px;" text="Producto activo" />
                </VBox>
            </GridPane>
        </VBox>

        <!-- BARRA DE ACCIONES -->
        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-background-color: white; -fx-padding: 14 28 14 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, -2, 0);">
            <Label style="-fx-font-size: 11px; -fx-text-fill: #9BBDD6;" text="* Campos obligatorios" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnConsultar" onAction="#abrirConsulta" prefHeight="40" prefWidth="130" styleClass="btn-primary" text="🔍 Consultar" />
            <Button fx:id="btnLimpiar" onAction="#limpiarCampos" prefHeight="40" prefWidth="120" styleClass="btn-secondary" text="🧹 Limpiar" />
            <Button fx:id="btnEliminar" onAction="#eliminarProducto" prefHeight="40" prefWidth="130" styleClass="btn-danger" text="🗑 Eliminar" />
            <Button fx:id="btnEditar" onAction="#editarProducto" prefHeight="40" prefWidth="130" styleClass="btn-success" text="✏ Editar" />
            <Button fx:id="btnGuardar" onAction="#guardarProducto" prefHeight="40" prefWidth="170" styleClass="btn-primary" text="✔ Guardar" />
        </HBox>
    </VBox>
</ScrollPane>