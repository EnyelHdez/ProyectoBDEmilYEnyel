<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #EEF4FB;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.PantallaPrincipalController">

    <left>
        <VBox minWidth="250.0" prefWidth="250.0" spacing="0" style="-fx-background-color: #1A6BAD;">

            <VBox alignment="CENTER" spacing="8" style="-fx-padding: 30 16 24 16;">
                <Label style="-fx-font-size: 48px; -fx-text-fill: #A8D8F0;" text="🏥" />
                <Label style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;" text="Farmacia Kenia Carmen" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #7BBEDE;" text="Sistema de Gestion" />
            </VBox>

            <VBox spacing="5" style="-fx-background-color: #2A85CF; -fx-padding: 12 16;">
                <Label fx:id="lblUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="👤 Cargando..." />
                <Label fx:id="lblCargo" style="-fx-text-fill: #A8D8F0; -fx-font-size: 11px;" text="📋 Cargando..." />
                <Separator style="-fx-background-color: #3A7AAD;" />
                <Label fx:id="lblNombreUsuario" style="-fx-text-fill: #A8D8F0; -fx-font-size: 10px;" text="Cargando..." />
            </VBox>

            <Rectangle fill="#2A85CF" height="2" />

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="4" style="-fx-padding: 16 12 16 12;">

                    <Label style="-fx-text-fill: #7BBEDE; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12;" text="MODULO PRINCIPAL" />

                    <Button fx:id="btnClientes" onAction="#abrirClientes" prefHeight="44" text="👥  Clientes" />
                    <Button fx:id="btnVentas" onAction="#abrirVentas" prefHeight="44" text="💰  Ventas" />
                    <Button fx:id="btnProductos" onAction="#abrirProductos" prefHeight="44" text="💊  Productos" />
                    <Button fx:id="btnCompras" onAction="#abrirCompras" prefHeight="44" text="📦  Compras" />

                    <Separator prefHeight="2" style="-fx-background-color: #2A85CF;" />

                    <Label style="-fx-text-fill: #7BBEDE; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12;" text="ADMINISTRACION" />

                    <Button fx:id="btnEmpleados" onAction="#abrirEmpleados" prefHeight="44" text="👔  Empleados" />
                    <Button fx:id="btnProveedores" onAction="#abrirProveedores" prefHeight="44" text="🚚  Proveedores" />
                    <Button fx:id="btnPedidos" onAction="#abrirPedidos" prefHeight="44" text="📄  Pedidos" />
                    <Button fx:id="btnPagos" onAction="#abrirPagos" prefHeight="44" text="💳  Pagos" />

                    <Separator prefHeight="2" style="-fx-background-color: #2A85CF;" />

                    <Label style="-fx-text-fill: #7BBEDE; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12;" text="OPERACIONES" />

                    <Button fx:id="btnEnvios" onAction="#abrirEnvios" prefHeight="44" text="📮  Envios" />
                    <Button fx:id="btnDevoluciones" onAction="#abrirDevoluciones" prefHeight="44" text="🔄  Devoluciones" />
                    <Button fx:id="btnReclamaciones" onAction="#abrirReclamaciones" prefHeight="44" text="📝  Reclamaciones" />
                    <Button fx:id="btnOrdenCompra" onAction="#abrirOrdenCompra" prefHeight="44" text="🧾  Orden de Compra" />
                    <Button fx:id="btnConvenios" onAction="#abrirConvenios" prefHeight="44" text="🤝  Convenios" />

                </VBox>
            </ScrollPane>

            <Rectangle fill="#2A85CF" height="1" />

            <VBox spacing="8" style="-fx-padding: 16;">
                <Label style="-fx-text-fill: #3A7AAD; -fx-font-size: 10px;" text="v1.0  ·  Sistema de Gestion" />
                <Label style="-fx-text-fill: #3A7AAD; -fx-font-size: 10px;" text="© 2024 - Kenia Carmen" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-padding: 16 28 16 28; -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, 0, 2);">

                <VBox spacing="2">
                    <Label fx:id="lblTituloPantalla" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;" text="Panel Principal" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7FA8C9;" text="Farmacia Kenia Carmen  ·  Sistema de Gestion Integral" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnCerrarSesion" onAction="#cerrarSesion" prefHeight="36" prefWidth="120" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12px;" text="🚪  Cerrar Sesion" />

                <Button fx:id="btnInicio" onAction="#irAInicio" prefHeight="36" prefWidth="90" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12px;" text="🏠  Inicio" />

                <Label fx:id="lblBadgeEstado" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1A7A40; -fx-background-color: #DFF5E8; -fx-padding: 6 14; -fx-background-radius: 20;" text="● Sistema Activo" />
            </HBox>

            <StackPane fx:id="contenedorPrincipal" style="-fx-background-color: #EEF4FB; -fx-padding: 0;" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>