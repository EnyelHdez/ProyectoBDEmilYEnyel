<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane  stylesheets="@estilos.css" prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #EEF4FB;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.proyecto.Controladores.PantallaPrincipalController">

    <!-- SIDEBAR IZQUIERDO -->
    <left>
        <VBox minWidth="250.0" prefWidth="250.0" spacing="0" style="-fx-background-color: #1A6BAD;">
            <!-- Logo / Header del sidebar -->
            <VBox alignment="CENTER" spacing="8" style="-fx-padding: 30 16 24 16;">
                <Label style="-fx-font-size: 48px; -fx-text-fill: #A8D8F0;" text="🏥" />
                <Label style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"
                       text="Farmacia Kenia Carmen" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #7BBEDE;" text="Sistema de Gestión" />
            </VBox>

            <Rectangle fill="#2A85CF" height="2" />

            <!-- Menú de navegación -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox spacing="4" style="-fx-padding: 16 12 16 12;">

                    <Label style="-fx-text-fill: #7BBEDE; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12;"
                           text="MÓDULO PRINCIPAL" />

                    <Button fx:id="btnClientes" onAction="#abrirClientes" prefHeight="44"
                            styleClass="menu-button" text="👥  Clientes" />

                    <Button fx:id="btnVentas" onAction="#abrirVentas" prefHeight="44"
                            styleClass="menu-button" text="💰  Ventas" />

                    <Button fx:id="btnProductos" onAction="#abrirProductos" prefHeight="44"
                            styleClass="menu-button" text="💊  Productos" />

                    <Button fx:id="btnCompras" onAction="#abrirCompras" prefHeight="44"
                            styleClass="menu-button" text="📦  Compras" />

                    <Separator style="-fx-background-color: #2A85CF;" prefHeight="2" />

                    <Label style="-fx-text-fill: #7BBEDE; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12;"
                           text="ADMINISTRACIÓN" />

                    <Button fx:id="btnEmpleados" onAction="#abrirEmpleados" prefHeight="44"
                            styleClass="menu-button" text="👔  Empleados" />

                    <Button fx:id="btnProveedores" onAction="#abrirProveedores" prefHeight="44"
                            styleClass="menu-button" text="🚚  Proveedores" />

                    <Button fx:id="btnPedidos" onAction="#abrirPedidos" prefHeight="44"
                            styleClass="menu-button" text="📄  Pedidos" />

                    <Button fx:id="btnPagos" onAction="#abrirPagos" prefHeight="44"
                            styleClass="menu-button" text="💳  Pagos" />

                    <Separator style="-fx-background-color: #2A85CF;" prefHeight="2" />

                    <Label style="-fx-text-fill: #7BBEDE; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12;"
                           text="OPERACIONES" />

                    <Button fx:id="btnEnvios" onAction="#abrirEnvios" prefHeight="44"
                            styleClass="menu-button" text="📮  Envíos" />

                    <Button fx:id="btnDevoluciones" onAction="#abrirDevoluciones" prefHeight="44"
                            styleClass="menu-button" text="🔄  Devoluciones" />

                    <Button fx:id="btnReclamaciones" onAction="#abrirReclamaciones" prefHeight="44"
                            styleClass="menu-button" text="📝  Reclamaciones" />

                    <Button fx:id="btnOrdenCompra" onAction="#abrirOrdenCompra" prefHeight="44"
                            styleClass="menu-button" text="🧾  Orden de Compra" />

                </VBox>
            </ScrollPane>

            <Rectangle fill="#2A85CF" height="1" />

            <!-- Footer del sidebar -->
            <VBox spacing="8" style="-fx-padding: 16;">
                <Label style="-fx-text-fill: #3A7AAD; -fx-font-size: 10px;" text="v1.0  ·  Sistema de Gestión" />
                <Label style="-fx-text-fill: #3A7AAD; -fx-font-size: 10px;" text="© 2024 - Kenia Carmen" />
            </VBox>
        </VBox>
    </left>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <VBox spacing="0">
            <!-- HEADER SUPERIOR -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white; -fx-padding: 16 28 16 28;
                         -fx-effect: dropshadow(gaussian, rgba(0,80,160,0.08), 6, 0, 0, 2);">

                <VBox spacing="2">
                    <Label fx:id="lblTituloPantalla"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A4F7A;"
                           text="Panel Principal" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7FA8C9;"
                           text="Farmacia Kenia Carmen  ·  Sistema de Gestión Integral" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnInicio" onAction="#irAInicio" prefHeight="36" prefWidth="90"
                        style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 12px;"
                        text="🏠  Inicio" />

                <Label fx:id="lblBadgeEstado"
                       style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #1A7A40;
                              -fx-background-color: #DFF5E8; -fx-padding: 6 14; -fx-background-radius: 20;"
                       text="● Sistema Activo" />
            </HBox>

            <!-- ÁREA DE CONTENIDO DINÁMICO -->
            <StackPane fx:id="contenedorPrincipal"
                       style="-fx-background-color: #EEF4FB; -fx-padding: 0;"
                       VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>