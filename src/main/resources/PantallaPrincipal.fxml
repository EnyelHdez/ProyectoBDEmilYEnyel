<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #F4F7FC;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.PantallaPrincipalController">

    <!-- SIDEBAR IZQUIERDO -->
    <left>
        <VBox minWidth="280.0" prefWidth="280.0" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #0F2B3D, #1A4F6E); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 8, 0, 2, 0);">

            <!-- Logo / Header del sidebar -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 35 20 25 20; -fx-background-color: rgba(255,255,255,0.05);">
                <Label style="-fx-font-size: 52px; -fx-text-fill: #7BC6E8;" text="🏥" />
                <Label style="-fx-font-size: 17px; -fx-text-fill: white; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;" text="Farmacia Kenia Carmen" />
                <Label style="-fx-font-size: 10px; -fx-text-fill: #9AC9E8;" text="Sistema de Gestión Integral" />
            </VBox>

            <!-- Información del usuario logueado -->
            <VBox spacing="6" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 15 18;">
                <Label fx:id="lblUsuario" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;" text="👤 Cargando..." />
                <Label fx:id="lblCargo" style="-fx-text-fill: #9AC9E8; -fx-font-size: 11px;" text="📋 Cargando..." />
                <Separator style="-fx-background-color: #2C5A7A;" />
                <Label fx:id="lblNombreUsuario" style="-fx-text-fill: #9AC9E8; -fx-font-size: 10px;" text="Cargando..." />
            </VBox>

            <Rectangle fill="#2C5A7A" height="2" />

            <!-- Menú de navegación -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="6" style="-fx-padding: 16 12;">

                    <!-- MÓDULO PRINCIPAL -->
                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="━━━━━ MÓDULO PRINCIPAL ━━━━━" />

                    <Button fx:id="btnClientes" onAction="#abrirClientes" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="👥  Clientes" />
                    <Button fx:id="btnVentas" onAction="#abrirVentas" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="💰  Ventas" />
                    <Button fx:id="btnProductos" onAction="#abrirProductos" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="💊  Productos" />
                    <Button fx:id="btnCompras" onAction="#abrirCompras" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📦  Compras" />

                    <Separator prefHeight="1" style="-fx-background-color: #2C5A7A; -fx-padding: 4 0;" />

                    <!-- ADMINISTRACIÓN -->
                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="━━━━━ ADMINISTRACIÓN ━━━━━" />

                    <Button fx:id="btnUsuarios" onAction="#abrirUsuarios" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="👥  Usuarios" />
                    <Button fx:id="btnEmpleados" onAction="#abrirEmpleados" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="👔  Empleados" />
                    <Button fx:id="btnProveedores" onAction="#abrirProveedores" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="🚚  Proveedores" />
                    <Button fx:id="btnPedidos" onAction="#abrirPedidos" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📄  Pedidos" />
                    <Button fx:id="btnPagos" onAction="#abrirPagos" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="💳  Pagos" />
                    <Button fx:id="btnConvenios" onAction="#abrirConvenios" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="🤝  Convenios" />
                    <Button fx:id="btnNominas" onAction="#abrirNominas" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📋  Nómina" />

                    <Separator prefHeight="1" style="-fx-background-color: #2C5A7A; -fx-padding: 4 0;" />

                    <!-- OPERACIONES -->
                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="━━━━━ OPERACIONES ━━━━━" />

                    <Button fx:id="btnOrdenCompra" onAction="#abrirOrdenCompra" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="🧾  Orden de Compra" />
                    <Button fx:id="btnEnvios" onAction="#abrirEnvios" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📮  Envíos" />
                    <Button fx:id="btnDevoluciones" onAction="#abrirDevoluciones" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="🔄  Devoluciones" />
                    <Button fx:id="btnPerdidas" onAction="#abrirPerdidas" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="⚠️  Pérdidas" />

                    <Separator prefHeight="1" style="-fx-background-color: #2C5A7A; -fx-padding: 4 0;" />

                    <!-- FARMACIA -->
                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="━━━━━ FARMACIA ━━━━━" />

                    <Button fx:id="btnMedicamentos" onAction="#abrirMedicamentos" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="💊  Medicamentos" />
                    <Button fx:id="btnCatalogo" onAction="#abrirCatalogo" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📚  Catálogo de Productos" />
                    <Button fx:id="btnRecetas" onAction="#abrirRecetas" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📋  Recetas Médicas" />
                    <Button fx:id="btnFidelizacion" onAction="#abrirFidelizacion" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="⭐  Fidelización" />
                    <Button fx:id="btnReclamaciones" onAction="#abrirReclamaciones" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📝  Reclamaciones" />
                    <Button fx:id="btnHistorialReclamaciones" onAction="#abrirHistorialReclamaciones" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="📊  Historial Reclamaciones" />
                    <Button fx:id="btnCuentasPago" onAction="#abrirCuentasPago" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 12px; -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 16; -fx-background-radius: 10; -fx-cursor: hand;" text="💳  Cuentas de Pago" />

                </VBox>
            </ScrollPane>

            <Rectangle fill="#2C5A7A" height="1" />

            <!-- Footer del sidebar -->
            <VBox spacing="6" style="-fx-padding: 15; -fx-alignment: CENTER;">
                <Label style="-fx-text-fill: #6A9AB8; -fx-font-size: 9px;" text="v2.0  ·  Sistema de Gestión" />
                <Label style="-fx-text-fill: #6A9AB8; -fx-font-size: 9px;" text="© 2025 - Farmacia Kenia Carmen" />
            </VBox>
        </VBox>
    </left>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <VBox spacing="0">
            <!-- HEADER SUPERIOR -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: white; -fx-padding: 12 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">

                <VBox spacing="2">
                    <Label fx:id="lblTituloPantalla" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A4F6E;" text="Panel Principal" />
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7A9FBB;" text="Farmacia Kenia Carmen  ·  Sistema de Gestión Integral" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnCerrarSesion" onAction="#cerrarSesion" prefHeight="36" prefWidth="120" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 11px;" text="🚪  Cerrar Sesión" />

                <Button fx:id="btnInicio" onAction="#irAInicio" prefHeight="36" prefWidth="80" style="-fx-background-color: #1A6BAD; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-size: 11px;" text="🏠  Inicio" />

                <Label fx:id="lblBadgeEstado" style="-fx-font-weight: bold; -fx-font-size: 10px; -fx-text-fill: #1E7A4A; -fx-background-color: #E0F5EA; -fx-padding: 5 14; -fx-background-radius: 20;" text="● Sistema Activo" />
            </HBox>

            <!-- ÁREA DE CONTENIDO DINÁMICO -->
            <StackPane fx:id="contenedorPrincipal" style="-fx-background-color: #F4F7FC; -fx-padding: 20;" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>