<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #F4F7FC;" stylesheets="@estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.proyecto.Controladores.PantallaPrincipalController">

    <!-- SIDEBAR IZQUIERDO -->
    <left>
        <VBox minWidth="260.0" prefWidth="260.0" spacing="0" style="-fx-background-color: linear-gradient(to bottom, #0F2B3D, #1A4F6E); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 8, 0, 2, 0);">

            <!-- Logo / Header del sidebar -->
            <VBox alignment="CENTER" spacing="10" style="-fx-padding: 35 20 25 20; -fx-background-color: rgba(255,255,255,0.05);">
                <Label style="-fx-font-size: 52px; -fx-text-fill: #7BC6E8;" text="🏥" />
                <Label style="-fx-font-size: 17px; -fx-text-fill: white; -fx-font-weight: bold; -fx-letter-spacing: 0.5px;" text="Farmacia Kenia Carmen" />
                <Label style="-fx-font-size: 11px; -fx-text-fill: #9AC9E8;" text="Sistema de Gestión" />
            </VBox>

            <!-- Información del usuario logueado -->
            <VBox spacing="6" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 15 18;">
                <Label fx:id="lblUsuario" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" text="👤 Cargando..." />
                <Label fx:id="lblCargo" style="-fx-text-fill: #9AC9E8; -fx-font-size: 11px;" text="📋 Cargando..." />
                <Separator style="-fx-background-color: #2C5A7A;" />
                <Label fx:id="lblNombreUsuario" style="-fx-text-fill: #9AC9E8; -fx-font-size: 10px;" text="Cargando..." />
            </VBox>

            <Rectangle fill="#2C5A7A" height="2" />

            <!-- Menú de navegación -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="6" style="-fx-padding: 20 16;">

                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="MÓDULO PRINCIPAL" />

                    <Button fx:id="btnClientes" onAction="#abrirClientes" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Clientes" />
                    <Button fx:id="btnVentas" onAction="#abrirVentas" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Ventas" />
                    <Button fx:id="btnProductos" onAction="#abrirProductos" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Productos" />
                    <Button fx:id="btnCompras" onAction="#abrirCompras" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Compras" />

                    <Separator prefHeight="2" style="-fx-background-color: #2C5A7A; -fx-padding: 8 0;" />

                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="ADMINISTRACIÓN" />

                    <Button fx:id="btnUsuarios" onAction="#abrirUsuarios" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Usuarios" />
                    <Button fx:id="btnEmpleados" onAction="#abrirEmpleados" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Empleados" />
                    <Button fx:id="btnProveedores" onAction="#abrirProveedores" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Proveedores" />
                    <Button fx:id="btnPedidos" onAction="#abrirPedidos" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Pedidos" />
                    <Button fx:id="btnPagos" onAction="#abrirPagos" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Pagos" />


                    <Separator prefHeight="2" style="-fx-background-color: #2C5A7A; -fx-padding: 8 0;" />
                    

                    <!-- OPERACIONES -->
                    <Label style="-fx-text-fill: #7BC6E8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 8 0 4 12; -fx-letter-spacing: 0.8px;" text="OPERACIONES" />

                    <Button fx:id="btnEnvios" onAction="#abrirEnvios" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Envios" />
                    <Button fx:id="btnDevoluciones" onAction="#abrirDevoluciones" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Devoluciones" />
                    <Button fx:id="btnFidelizacion" onAction="#abrirFidelizacion" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Fidelizacion" />
                    <Button fx:id="btnReclamaciones" onAction="#abrirReclamaciones" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Reclamaciones" />
                    <Button fx:id="btnMedicamentos" onAction="#abrirMedicamentos" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Medicamentos" />
                    <Button fx:id="btnRecetas" onAction="#abrirRecetas" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Recetas Medicas" />
                    <Button fx:id="btnPerdidas" onAction="#abrirPerdidas" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Perdidas" />
                    <Button fx:id="btnCuentasPago" onAction="#abrirCuentasPago" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Cuentas de Pago" />
                    <Button fx:id="btnHistorialReclamaciones" onAction="#abrirHistorialReclamaciones" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Historial Reclamaciones" />
                    <Button fx:id="btnOrdenCompra" onAction="#abrirOrdenCompra" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Orden de Compra" />
                    <Button fx:id="btnConvenios" onAction="#abrirConvenios" maxWidth="Infinity" prefHeight="38" styleClass="menu-button" text="Convenios" />

                </VBox>
            </ScrollPane>

            <Rectangle fill="#2C5A7A" height="1" />

            <!-- Footer del sidebar -->
            <VBox spacing="6" style="-fx-padding: 18; -fx-alignment: CENTER;">
                <Label style="-fx-text-fill: #6A9AB8; -fx-font-size: 10px;" text="v1.0  ·  Sistema de Gestión" />
                <Label style="-fx-text-fill: #6A9AB8; -fx-font-size: 10px;" text="© 2024 - Kenia Carmen" />
            </VBox>
        </VBox>
    </left>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <VBox spacing="0">
            <!-- HEADER SUPERIOR -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: white; -fx-padding: 16 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">

                <VBox spacing="4">
                    <Label fx:id="lblTituloPantalla" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A4F6E;" text="Panel Principal" />
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #7A9FBB;" text="Farmacia Kenia Carmen  ·  Sistema de Gestión Integral" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnCerrarSesion" onAction="#cerrarSesion" prefHeight="38" prefWidth="130" styleClass="btn-danger" text="Cerrar Sesion" />

                <Button fx:id="btnInicio" onAction="#irAInicio" prefHeight="38" prefWidth="90" styleClass="btn-primary" text="Inicio" />

                <Label fx:id="lblBadgeEstado" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #1E7A4A; -fx-background-color: #E0F5EA; -fx-padding: 6 16; -fx-background-radius: 30;" text="● Sistema Activo" />
            </HBox>

            <!-- ÁREA DE CONTENIDO DINÁMICO -->
            <StackPane fx:id="contenedorPrincipal" style="-fx-background-color: #F4F7FC; -fx-padding: 24;" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>